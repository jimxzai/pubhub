% ============================================================
% CHAPTER & SECTION STYLING
% ============================================================
\makeatletter
\def\@makechapterhead#1{%
  \vspace*{20\p@}%
  {\parindent \z@ \raggedright \normalfont
    \begin{tikzpicture}[remember picture,overlay]
      \draw[color=accentgold,line width=1.5pt] (0,0) -- (0.8,0);
      \filldraw[color=accentgold] (0.9,0) circle (2pt);
    \end{tikzpicture}%
    \par\vskip 8\p@
    \ifnum \c@secnumdepth >\m@ne
      \if@mainmatter
        {\color{accentgold}\rule{\textwidth}{2pt}}
        \par\nobreak\vskip 15\p@
        {\sffamily\LARGE\bfseries\color{chapterblue} \@chapapp\ \thechapter}
        \par\nobreak
        \vskip 10\p@
      \fi
    \fi
    \interlinepenalty\@M
    {\sffamily\Huge\bfseries\color{chapterblue} #1}
    \par\nobreak
    \vskip 8\p@
    {\color{accentgold}\rule{\textwidth}{0.5pt}}
    \vskip 30\p@
  }}
\def\@makeschapterhead#1{%
  \vspace*{30\p@}%
  {\parindent \z@ \raggedright
    \normalfont
    {\color{accentgold}\rule{\textwidth}{2pt}}
    \par\nobreak\vskip 15\p@
    \interlinepenalty\@M
    {\sffamily\Huge\bfseries\color{chapterblue} #1}
    \par\nobreak
    \vskip 8\p@
    {\color{accentgold}\rule{\textwidth}{0.5pt}}
    \vskip 30\p@
  }}
\makeatother

\makeatletter
\renewcommand\section{\@startsection {section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\sffamily\Large\bfseries\color{sectionblue}}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\sffamily\large\bfseries\color{chapterblue}}}
\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1ex \@plus .2ex}%
  {\sffamily\normalsize\bfseries\color{chapterblue!80}}}
\makeatother

% ============================================================
% PART PAGE STYLING
% ============================================================
\makeatletter
\def\@part[#1]#2{%
  \ifnum \c@secnumdepth >-2\relax
    \refstepcounter{part}%
    \addcontentsline{toc}{part}{\thepart\hspace{1em}#1}%
  \else
    \addcontentsline{toc}{part}{#1}%
  \fi
  \markboth{}{}%
  \thispagestyle{empty}%
  \begin{tikzpicture}[remember picture,overlay]
    \draw[color=accentgold,line width=1.5pt] (current page.north west) ++(1.5in,-1.5in) -- ++(0.8in,0);
    \draw[color=accentgold,line width=1.5pt] (current page.north west) ++(1.5in,-1.5in) -- ++(0,0.8in);
    \draw[color=accentgold,line width=1.5pt] (current page.north east) ++(-1.5in,-1.5in) -- ++(-0.8in,0);
    \draw[color=accentgold,line width=1.5pt] (current page.north east) ++(-1.5in,-1.5in) -- ++(0,0.8in);
  \end{tikzpicture}%
  \vspace*{2cm}%
  \begin{center}%
    {\color{accentgold}\rule{\textwidth}{3pt}}%
    \par\vskip 25pt%
    \ifnum \c@secnumdepth >-2\relax
      {\sffamily\large\bfseries\color{chapterblue!60}\MakeUppercase{\partname}\ \thepart}%
      \par\vskip 12pt%
    \fi
    {\sffamily\fontsize{32}{38}\selectfont\bfseries\color{chapterblue}#2}%
    \par\vskip 25pt%
    \begin{tikzpicture}
      \draw[color=accentgold, line width=1.5pt] (0,0) -- (3,0);
      \filldraw[color=accentgold] (3.2,0) -- (3.5,0.2) -- (3.8,0) -- (3.5,-0.2) -- cycle;
      \draw[color=accentgold, line width=1.5pt] (3.8,0) -- (6.8,0);
    \end{tikzpicture}%
    \par\vskip 15pt%
    {\color{accentgold}\rule{3cm}{0.5pt}}%
  \end{center}%
  \begin{tikzpicture}[remember picture,overlay]
    \draw[color=accentgold,line width=1.5pt] (current page.south west) ++(1.5in,1.5in) -- ++(0.8in,0);
    \draw[color=accentgold,line width=1.5pt] (current page.south west) ++(1.5in,1.5in) -- ++(0,-0.8in);
    \draw[color=accentgold,line width=1.5pt] (current page.south east) ++(-1.5in,1.5in) -- ++(-0.8in,0);
    \draw[color=accentgold,line width=1.5pt] (current page.south east) ++(-1.5in,1.5in) -- ++(0,-0.8in);
  \end{tikzpicture}%
  \@endpart}
\def\@spart#1{%
  \thispagestyle{empty}%
  \vspace*{2cm}%
  \begin{center}%
    {\color{accentgold}\rule{\textwidth}{3pt}}%
    \par\vskip 25pt%
    {\sffamily\fontsize{32}{38}\selectfont\bfseries\color{chapterblue}#1}%
    \par\vskip 25pt%
    {\color{accentgold}\rule{6cm}{1.5pt}}%
    \par\vskip 15pt%
    {\color{accentgold}\rule{3cm}{0.5pt}}%
  \end{center}%
  \@endpart}
\def\@endpart{\vfil\newpage}
\makeatother

