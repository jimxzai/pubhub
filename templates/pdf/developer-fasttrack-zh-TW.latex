% ============================================================
% TABLE OF CONTENTS STYLING
% ============================================================
\makeatletter
\renewcommand*\l@part[2]{%
  \ifnum \c@tocdepth >-2\relax
    \addpenalty{-\@highpenalty}%
    \addvspace{2em \@plus\p@}%
    \setlength\@tempdima{3em}%
    \begingroup
      \parindent \z@ \rightskip \@pnumwidth
      \parfillskip -\@pnumwidth
      {\leavevmode
        \sffamily\large\bfseries\color{chapterblue}#1\hfil
        \hb@xt@\@pnumwidth{\hss\color{chapterblue}#2}}\par
      \nobreak
    \endgroup
    \vskip 4pt
    {\color{accentgold}\rule{\textwidth}{0.4pt}}
    \vskip 4pt
  \fi}
\renewcommand*\l@chapter[2]{%
  \ifnum \c@tocdepth >\m@ne
    \addpenalty{-\@highpenalty}%
    \vskip 6\p@ \@plus\p@
    \setlength\@tempdima{2.2em}%
    \begingroup
      \parindent \z@ \rightskip \@pnumwidth
      \parfillskip -\@pnumwidth
      \leavevmode \sffamily\bfseries\color{chapterblue}%
      \advance\leftskip\@tempdima
      \hskip -\leftskip
      #1\nobreak\hfil
      \nobreak\hb@xt@\@pnumwidth{\hss #2\kern-\p@\kern\p@}\par
      \penalty\@highpenalty
    \endgroup
  \fi}
\renewcommand*\l@section[2]{%
  \ifnum \c@tocdepth >\z@
    \vskip 2\p@
    \setlength\@tempdima{3em}%
    \begingroup
      \parindent \z@
      \rightskip \@pnumwidth
      \parfillskip -\@pnumwidth
      \leavevmode
      \advance\leftskip 2.2em
      \hskip -\leftskip
      {\color{chapterblue!80}#1}\nobreak
      {\color{accentgold!60}\leaders\hbox{$$\m@th
        \mkern \@dotsep mu\hbox{.}\mkern \@dotsep mu$$}\hfill}%
      \nobreak\hb@xt@\@pnumwidth{\hss\color{chapterblue!70}#2}\par
    \endgroup
  \fi}
\renewcommand*\l@subsection[2]{%
  \ifnum \c@tocdepth >1
    \vskip 1\p@
    \setlength\@tempdima{3.8em}%
    \begingroup
      \parindent \z@
      \rightskip \@pnumwidth
      \parfillskip -\@pnumwidth
      \leavevmode\small
      \advance\leftskip 5.2em
      \hskip -\leftskip
      {\color{chapterblue!60}#1}\nobreak
      {\color{accentgold!40}\leaders\hbox{$$\m@th
        \mkern \@dotsep mu\hbox{.}\mkern \@dotsep mu$$}\hfill}%
      \nobreak\hb@xt@\@pnumwidth{\hss\color{chapterblue!50}#2}\par
    \endgroup
  \fi}
\makeatother

