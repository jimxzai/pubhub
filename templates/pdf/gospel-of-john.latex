%% ============================================
%% APPENDIX D: ABOUT RED LETTER BIBLE
%% ============================================
\chapter*{附錄四：紅字聖經說明 (Appendix D: About the Red Letter Format)}
\addcontentsline{toc}{chapter}{附錄四：紅字聖經說明 (Appendix D: About the Red Letter Format)}
\markboth{}{}

\section*{什麼是紅字聖經？}

紅字聖經是一種聖經印刷傳統，將耶穌基督親口所說的話用\textcolor{JesusRed}{紅色}印刷，以區別於敘事文字與他人話語。這種格式起源於1899年，由 Louis Klopsch 首先用於英文聖經。

\section*{本書的紅字標記}

\begin{itemize}
\item \textcolor{JesusRed}{\textit{耶穌直接說的話}} —— 紅色標示
\item 敘事文字、他人話語 —— 黑色正體
\item 舊約引文 —— 保留原樣，不作紅字處理
\end{itemize}

\section*{紅字的神學意義}

\begin{enumerate}
\item 耶穌的話語帶著神自己的權柄——「神既在古時藉著眾先知……就在這末世藉著他兒子曉諭我們」（來1:1-2）。
\item 約翰福音记载耶穌的話語比例極高，尤其13-17章幾乎整段都是紅字——這是祂向門徒掏心的那一夜。
\item 紅字提醒讀者：這不是一段引言，是「道」自己在說話。
\end{enumerate}

\vspace{0.5cm}
\begin{center}
\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{4.2in}
\centering\vspace{0.2cm}
\textcolor{JesusRed}{\textit{「我就是道路、真理、生命；\\
若不藉著我，沒有人能到父那裏去。」}}\\[0.3em]
\small — 約翰福音 14:6
\vspace{0.2cm}
\end{minipage}}
\end{center}

\pagebreak

%% ============================================
%% APPENDIX E: FOUR GOSPELS DISTINCTIVES (SIMPLIFIED)
%% ============================================
\chapter*{附錄五：約翰福音在四福音中的獨特性 (Appendix E: John Among the Four Gospels)}
\addcontentsline{toc}{chapter}{附錄五：約翰福音在四福音中的獨特性 (Appendix E: John Among the Four Gospels)}
\markboth{}{}

\section*{四福音四活物——四個角度寫同一位耶穌}

{\small
\begin{tabular}{@{}p{2.0cm}p{1.6cm}p{3.4cm}p{2.0cm}p{2.5cm}@{}}
\toprule
\textbf{福音書} & \textbf{活物} & \textbf{身份} & \textbf{開卷起點} & \textbf{家譜} \\
\midrule
馬太 & 獅子 & 王（大衛的子孫） & 亞伯拉罕 & 有（往下數到耶穌） \\
馬可 & 牛 & 僕人 & 施洗約翰出來 & 無（僕人不需家譜） \\
路加 & 人 & 完全人（末後的亞當） & 亞當 & 有（往上追到神） \\
\textbf{約翰} & \textbf{鷹} & \textbf{神（永恆的道）} & \textbf{太初} & \textbf{無（神沒有家譜）} \\
\bottomrule
\end{tabular}
}

\vspace{0.4cm}
\section*{約翰獨有、對觀福音沒有的材料}

\begin{itemize}
\item 序言（1:1-18「太初有道」）
\item 七個「我是」宣告
\item 尼哥底母、撒瑪利亞婦人的私人長談
\item 洗門徒的腳（13章）、樓上五章講論（13-17章）
\item 拉撒路復活（11章）
\item 大祭司的禱告（17章）
\end{itemize}

\section*{對觀福音有、約翰沒有的材料}

\begin{itemize}
\item 耶穌的降生、受洗場面、曠野受試探
\item 比喻——約翰福音一個比喻也沒有記載
\item 登山變像
\item 設立聖餐的敘述（約翰記洗腳取代之）
\item 客西馬尼的掙扎禱告細節
\end{itemize}

\noindent 約翰晚年寫作（約主後85-95年），對觀福音已流傳；他不是重寫，是\textbf{補足與升高}：對觀福音多記加利利事工，約翰多記耶路撒冷與猶太節期；對觀福音記「國度的福音」，約翰記「生命的福音」。三年半的事工年表，正是靠約翰所記的三個逾越節（2:13；6:4；11:55）才立起來的。

\pagebreak

%% ============================================
%% APPENDIX F: SEVEN SIGNS OF JOHN
%% ============================================
\chapter*{附錄六：約翰福音七大兆頭 (Appendix F: The Seven Signs of John)}
\addcontentsline{toc}{chapter}{附錄六：約翰福音七大兆頭 (Appendix F: The Seven Signs of John)}
\markboth{}{}

\noindent\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{6.0in}\vspace{0.18cm}
\centering
{\footnotesize\bfseries\color{ChapterBlue} 讀經之鑰 \;\textperiodcentered\; The Key}\\[0.4em]
{\footnotesize\color{TextGray}
約翰不用「神蹟」(\textit{dynamis}，權能的作為)，而用「兆頭」(\textit{sēmeion})——
每個兆頭都是\textbf{指向耶穌身份的記號}，不是用來炫耀的表演。}
\vspace{0.18cm}
\end{minipage}}

\vspace{0.3cm}

\noindent\textbf{總綱經文}（約20:30-31）：

\begin{center}
\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{5.5in}
\centering\vspace{0.15cm}
{\footnotesize\color{TextGray}
「耶穌在門徒面前另外行了許多神蹟，沒有記在這書上。但記載這些事是要使你們信耶穌是基督，是神的兒子，並且使你們信了，就可以因他的名得生命。」\\[0.15em]
\scriptsize — 約翰福音 20:30-31}
\vspace{0.15cm}
\end{minipage}}
\end{center}

\vspace{0.3cm}

\section*{1. 水變酒 (2:1-11)}
\noindent\textbf{地點：}加利利的迦拿婚宴\\
\noindent\textbf{記載：}「這是耶穌所行的頭一件兆頭，是在加利利的迦拿行的，顯出他的榮耀來」(2:11)\\
\noindent\textbf{屬靈意義：}六口猶太潔淨規矩用的石缸變成上好的酒——恩典（滿足需要）與真理（創造主大能）同時彰顯，遙相呼應15章「我是真葡萄樹」。

\vspace{0.2cm}
\section*{2. 醫治大臣之子 (4:46-54)}
\noindent\textbf{記載：}「這是耶穌從猶太到加利利以後所行的第二件神蹟」(4:54)\\
\noindent\textbf{屬靈意義：}耶穌的話語超越空間，隔空生效。信心不在乎眼見，而在乎所信的那句話。

\vspace{0.2cm}
\section*{3. 醫治畢士大池三十八年的病人 (5:1-15)}
\noindent\textbf{地點：}耶路撒冷畢士大池，安息日\\
\noindent\textbf{屬靈意義：}「你要痊癒嗎？」——律法（池水）救不了人，唯有耶穌的話。引出耶穌與父同工、同等的宣告（5:17-18）。

\vspace{0.2cm}
\section*{4. 五餅二魚餵飽五千人 (6:1-14)}
\noindent\textbf{唯一四福音都記載的兆頭}\\
\noindent\textbf{屬靈意義：}緊接著宣告「我是生命的糧」(6:35)——耶穌不僅供應糧，祂自己\textit{就是}糧。

\vspace{0.2cm}
\section*{5. 海面行走 (6:16-21)}
\noindent\textbf{記載：}「是我，不要怕」——原文 ἐγώ εἰμι，「我是」\\
\noindent\textbf{屬靈意義：}約翰福音第一次出現「我是」——出埃及記3:14耶和華的名字。海與風是受造之物，順服那創造者。

\vspace{0.2cm}
\section*{6. 醫治生來瞎眼的人 (9:1-41)}
\noindent\textbf{地點：}西羅亞池（譯出來就是「奉差遣」）\\
\noindent\textbf{屬靈意義：}緊接第8章「我是世界的光」。物質之光開了瞎子的眼，屬靈之光要開的是靈魂的眼——本章結尾，自稱看得見的法利賽人，才是真正的瞎子。

\vspace{0.2cm}
\section*{7. 拉撒路復活 (11:1-44)}
\noindent\textbf{記載：}「復活在我，生命也在我」(11:25)——這句話說在叫死人出來\textbf{之前}\\
\noindent\textbf{屬靈意義：}七兆頭的頂峰——不僅治病、不僅供應，乃是\textbf{勝過死亡}。這神蹟本身，也定了耶穌自己的死案（11:47-53）。

\vspace{0.3cm}
\noindent\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{6.0in}
\centering\vspace{0.2cm}
{\footnotesize\color{TextGray}
\textbf{結構觀察：}兆頭1（水變酒）與兆頭7（拉撒路復活）都是「無到有」的創造性作為；中間五個兆頭，是「殘缺到完整」的醫治與供應。}
\vspace{0.2cm}
\end{minipage}}

\vspace{0.3cm}
\noindent\textbf{帶領提問：}你曾為缺乏神蹟而失望嗎？兆頭是\textbf{記號}，不是\textbf{目的}——記號指向祂的榮光。今天，從哪一個兆頭裡，你看見了祂？

\pagebreak

%% ============================================
%% APPENDIX G: PSALMS & OT MESSIANIC PROPHECIES
%% ============================================
\chapter*{附錄七：詩篇與舊約彌賽亞預言 (Appendix G: Psalms \& OT Messianic Prophecies)}
\addcontentsline{toc}{chapter}{附錄七：詩篇與舊約彌賽亞預言 (Appendix G: Psalms \& OT Messianic Prophecies)}
\markboth{}{}

\noindent 以下所列，均為約翰福音經文\textbf{明文引用}的舊約預言，依約翰福音章節順序排列——不是泛泛的相似，而是約翰或耶穌自己親口指明的應驗關係。

{\small
\begin{longtable}{@{}p{2.0cm}p{4.5cm}p{2.2cm}p{4.9cm}@{}}
\toprule
\textbf{約翰福音} & \textbf{內容} & \textbf{舊約出處} & \textbf{應驗方式} \\
\midrule
\endhead
1:23 & 施洗約翰自我指認 & 賽40:3 & 「我就是那在曠野呼喊者的聲音」——明文引用 \\
2:17 & 潔淨聖殿，門徒想起經上的話 & 詩69:9 & 「我為你的殿心裏焦急，如同火燒」 \\
6:31 & 群眾求餅，引用經上的話 & 出16:4；詩78:24 & 「他從天上賜下糧食給他們吃」 \\
10:34 & 耶穌回應「你是人，自命為神」的指控 & 詩82:6 & 「我曾說你們是神」 \\
12:13-15 & 榮耀進城 & 亞9:9；詩118:25-26 & 「和散那」；「你的王來了，騎著驢駒子」——雙重明文引用 \\
12:38 & 猶太人不信的原因 & 賽53:1 & 「主啊，我們所傳的，有誰信呢」 \\
12:40 & 猶太人不能信的原因 & 賽6:10 & 「主叫他們瞎了眼，硬了心」 \\
13:18 & 猶大的背叛 & 詩41:9 & 「同我吃飯的人用腳踢我」 \\
15:25 & 世界無故恨惡耶穌 & 詩35:19；69:4 & 「他們無故地恨我」 \\
19:24 & 兵丁拈鬮分耶穌的外衣 & 詩22:18 & 「他們分我的外衣，為我的裏衣拈鬮」 \\
19:28 & 「我渴了」 & 詩69:21 & 「我渴了，他們拿醋給我喝」 \\
19:36 & 兵丁不打斷耶穌的腿 & 出12:46；詩34:20 & 「他的骨頭一根也不可折斷」——呼應逾越節羊羔條例 \\
19:37 & 兵丁用槍扎耶穌的肋旁 & 亞12:10 & 「他們要仰望自己所扎的人」 \\
\bottomrule
\end{longtable}
}

\vspace{0.3cm}
\noindent\textbf{未明文引用、但貫穿全書的預表：}逾越節羊羔（出12章 → 約1:29, 19:36）；銅蛇（民21:9 → 約3:14）；雅各天梯（創28:12 → 約1:51）；大祭司（利16章 → 約17章）；「那先知」（申18:15 → 約1:21, 45；6:14）。

