% 圣经英雄传 - 青少年版 (12岁以上)
% Heroes of the Bible for Teens (Age 12+)
% 简体中文版 + TikZ插画 + 经文引用 + 思考问题
% 涵盖旧约与新约的伟大人物：约瑟、摩西、参孙、路得、大卫、以利亚、耶稣、彼得、保罗

\documentclass[11pt,openany]{book}

% 页面设置 - 标准书籍格式
\usepackage[paperwidth=6in, paperheight=9in, margin=0.75in]{geometry}

% 字体设置
\usepackage{fontspec}
\setmainfont{Songti SC}[
  BoldFont={Songti SC Bold},
  ItalicFont={Kaiti SC},
  BoldItalicFont={Kaiti SC Bold},
  Scale=1.0
]
\setsansfont{PingFang SC}
\setmonofont{Menlo}

% 适合12岁以上青少年阅读，无需拼音

% 经文引用样式
\newcommand{\bibleverse}[1]{{\small\itshape「#1」}}

% 思考问题样式
\newcommand{\thinkbox}[1]{%
\vspace{0.15in}
\noindent\fbox{\parbox{0.95\textwidth}{%
{\small\bfseries 思考一下：}\\[0.05in]
{\small #1}
}}
\vspace{0.1in}
}

% TikZ绘图
\usepackage{tikz}
\usetikzlibrary{shapes,decorations,patterns,calc,positioning,shadows,arrows.meta}

% 颜色定义 - 温暖柔和的儿童色彩
\definecolor{SkyBlue}{RGB}{135,206,235}
\definecolor{SunYellow}{RGB}{255,223,0}
\definecolor{GrassGreen}{RGB}{124,185,95}
\definecolor{WarmBrown}{RGB}{165,113,78}
\definecolor{SoftPink}{RGB}{255,182,193}
\definecolor{CloudWhite}{RGB}{255,255,255}
\definecolor{NightBlue}{RGB}{25,25,112}
\definecolor{StarGold}{RGB}{255,215,0}
\definecolor{WaterBlue}{RGB}{100,149,237}
\definecolor{SandBeige}{RGB}{244,226,198}
\definecolor{HeartRed}{RGB}{220,53,69}
\definecolor{WoodBrown}{RGB}{139,90,43}

% 无页眉页脚
\pagestyle{empty}

% 段落设置
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

% ============================================
% TikZ 简约插画宏定义
% ============================================

% 1. 马槽里的婴儿耶稣 (诞生)
\newcommand{\mangerscene}{%
\begin{tikzpicture}[scale=1.0]
  % 夜空背景
  \fill[NightBlue] (0,0) rectangle (12,10);

  % 星星
  \foreach \x/\y in {1/9, 3/8.5, 5/9.2, 7/8, 9/9, 11/8.3, 2/7.5, 10/7.8} {
    \fill[StarGold] (\x,\y) circle (0.08);
  }

  % 大星星 (伯利恒之星)
  \fill[StarGold] (6,9) -- (6.3,8.3) -- (7,8.3) -- (6.4,7.8) -- (6.6,7) -- (6,7.5) -- (5.4,7) -- (5.6,7.8) -- (5,8.3) -- (5.7,8.3) -- cycle;

  % 马棚
  \fill[WoodBrown] (2,0) -- (2,4) -- (6,6) -- (10,4) -- (10,0) -- cycle;
  \fill[WarmBrown!50] (3,0) rectangle (9,3.5);

  % 马槽
  \fill[WoodBrown] (4.5,1) -- (4.5,2) -- (7.5,2) -- (7.5,1) -- (7,0.8) -- (5,0.8) -- cycle;
  \fill[SandBeige] (4.8,1.3) rectangle (7.2,1.9);

  % 婴儿耶稣 (简化圆形)
  \fill[SoftPink] (6,1.7) circle (0.4);
  \fill[CloudWhite] (5.3,1.2) rectangle (6.7,1.6);

  % 光环
  \draw[StarGold, line width=2pt] (6,1.9) circle (0.6);

  % 干草
  \foreach \x in {4.9, 5.2, 5.5, 6.5, 6.8, 7.1} {
    \draw[SandBeige, line width=1pt] (\x,1.3) -- (\x+0.1,1.8);
  }

  % 玛利亚 (简化)
  \fill[blue!60] (3,0) -- (3,3) -- (4,3.5) -- (4.5,2) -- (4,0) -- cycle;
  \fill[SoftPink] (3.5,3.3) circle (0.4);

  % 约瑟 (简化)
  \fill[WarmBrown!80] (8,0) -- (8,3.2) -- (9,3.5) -- (9.5,2) -- (9,0) -- cycle;
  \fill[SoftPink] (8.5,3.5) circle (0.4);
\end{tikzpicture}%
}

% 2. 牧羊人和天使
\newcommand{\shepherdsscene}{%
\begin{tikzpicture}[scale=1.0]
  % 夜空
  \fill[NightBlue] (0,5) rectangle (12,10);
  % 草地
  \fill[GrassGreen!70] (0,0) rectangle (12,5);

  % 星星
  \foreach \x/\y in {1/9, 3/8, 5/9, 9/8.5, 11/9} {
    \fill[StarGold] (\x,\y) circle (0.1);
  }

  % 天使 (简化三角形+圆形)
  \fill[CloudWhite] (6,8) -- (4.5,6) -- (7.5,6) -- cycle;
  \fill[SoftPink] (6,8.5) circle (0.5);
  % 翅膀
  \fill[CloudWhite!90] (4,7) -- (5,7.5) -- (5,6.5) -- cycle;
  \fill[CloudWhite!90] (8,7) -- (7,7.5) -- (7,6.5) -- cycle;
  % 光芒
  \draw[StarGold, line width=2pt] (6,7.5) circle (1.5);

  % 牧羊人 (简化)
  \fill[WarmBrown] (2,0) -- (2,2.5) -- (2.8,3) -- (3.2,2) -- (3,0) -- cycle;
  \fill[SoftPink] (2.5,3.2) circle (0.35);
  % 牧杖
  \draw[WoodBrown, line width=3pt] (1.5,0) -- (1.5,3.5) arc (180:0:0.3);

  % 羊
  \fill[CloudWhite] (4,1) ellipse (0.6 and 0.4);
  \fill[CloudWhite] (4.2,1.5) circle (0.25);
  \fill[CloudWhite] (8,0.8) ellipse (0.5 and 0.35);
  \fill[CloudWhite] (8.2,1.2) circle (0.2);
  \fill[CloudWhite] (10,1.2) ellipse (0.55 and 0.38);
  \fill[CloudWhite] (10.2,1.6) circle (0.22);
\end{tikzpicture}%
}

% 3. 三博士送礼物
\newcommand{\wisemenscene}{%
\begin{tikzpicture}[scale=1.0]
  % 沙漠背景
  \fill[SkyBlue!50] (0,5) rectangle (12,10);
  \fill[SandBeige] (0,0) rectangle (12,5);

  % 太阳
  \fill[SunYellow] (10,8) circle (1);

  % 星星
  \fill[StarGold] (3,9) -- (3.2,8.3) -- (3.9,8.3) -- (3.35,7.85) -- (3.55,7.1) -- (3,7.55) -- (2.45,7.1) -- (2.65,7.85) -- (2.1,8.3) -- (2.8,8.3) -- cycle;

  % 三位博士 (不同颜色)
  % 博士1 - 红色
  \fill[HeartRed!80] (2,0) -- (2,2.8) -- (3,3.2) -- (3.5,2) -- (3,0) -- cycle;
  \fill[SoftPink] (2.5,3.4) circle (0.4);
  \fill[StarGold] (2.5,3.8) -- (2.3,3.6) -- (2.7,3.6) -- cycle; % 皇冠

  % 博士2 - 蓝色
  \fill[blue!60] (5,0) -- (5,3) -- (6,3.4) -- (6.5,2.2) -- (6,0) -- cycle;
  \fill[SoftPink] (5.5,3.6) circle (0.4);
  \fill[StarGold] (5.5,4) -- (5.3,3.8) -- (5.7,3.8) -- cycle;

  % 博士3 - 绿色
  \fill[GrassGreen!80] (8,0) -- (8,2.6) -- (9,3) -- (9.5,1.8) -- (9,0) -- cycle;
  \fill[SoftPink] (8.5,3.2) circle (0.4);
  \fill[StarGold] (8.5,3.6) -- (8.3,3.4) -- (8.7,3.4) -- cycle;

  % 礼物盒子
  \fill[StarGold] (2.8,1.5) rectangle (3.2,1.9);
  \fill[StarGold] (6,1.8) rectangle (6.4,2.2);
  \fill[StarGold] (8.8,1.3) rectangle (9.2,1.7);

  % 骆驼 (简化)
  \fill[WarmBrown] (10.5,1) ellipse (0.8 and 0.5);
  \fill[WarmBrown] (11,1.8) -- (10.8,1.2) -- (11.2,1.2) -- cycle; % 驼峰
  \fill[WarmBrown] (10.8,1.8) circle (0.25); % 头
\end{tikzpicture}%
}

% 4. 耶稣受洗
\newcommand{\baptismscene}{%
\begin{tikzpicture}[scale=1.0]
  % 天空
  \fill[SkyBlue] (0,5) rectangle (12,10);
  % 河水
  \fill[WaterBlue] (0,0) rectangle (12,5);

  % 云朵
  \fill[CloudWhite] (3,8) ellipse (1.2 and 0.5);
  \fill[CloudWhite] (3.5,8.3) ellipse (0.8 and 0.4);
  \fill[CloudWhite] (9,8.5) ellipse (1 and 0.45);

  % 阳光从云中射下
  \draw[SunYellow, line width=3pt] (6,10) -- (6,6);
  \draw[SunYellow, line width=2pt] (5.5,10) -- (5.7,6.5);
  \draw[SunYellow, line width=2pt] (6.5,10) -- (6.3,6.5);

  % 鸽子 (圣灵)
  \fill[CloudWhite] (6,7) ellipse (0.5 and 0.3);
  \fill[CloudWhite] (5.5,7.2) -- (5,7.5) -- (5.5,7) -- cycle; % 翅膀
  \fill[CloudWhite] (6.5,7.2) -- (7,7.5) -- (6.5,7) -- cycle;
  \fill[CloudWhite] (6.3,7) circle (0.15); % 头

  % 耶稣在水中
  \fill[SoftPink] (6,4.5) circle (0.5); % 头
  \fill[CloudWhite] (5.3,3) -- (6,4) -- (6.7,3) -- (6.5,1.5) -- (5.5,1.5) -- cycle; % 身体

  % 光环
  \draw[StarGold, line width=2pt] (6,4.8) circle (0.7);

  % 约翰
  \fill[WarmBrown!80] (3,1.5) -- (3,3.5) -- (4,4) -- (4.5,3) -- (4,1.5) -- cycle;
  \fill[SoftPink] (3.5,4.2) circle (0.4);

  % 河岸
  \fill[SandBeige] (0,0) -- (0,1.5) -- (2,1) -- (0,0);
  \fill[SandBeige] (12,0) -- (12,1.5) -- (10,1) -- (12,0);

  % 水波纹
  \draw[WaterBlue!70, line width=1pt] (2,2) to[bend left] (4,2.2) to[bend right] (6,2);
  \draw[WaterBlue!70, line width=1pt] (6,2) to[bend left] (8,2.2) to[bend right] (10,2);
\end{tikzpicture}%
}

% 5. 耶稣讲道 (山上宝训)
\newcommand{\sermonscene}{%
\begin{tikzpicture}[scale=1.0]
  % 天空
  \fill[SkyBlue] (0,6) rectangle (12,10);
  % 山丘
  \fill[GrassGreen] (0,0) -- (0,4) -- (3,6) -- (6,7) -- (9,6) -- (12,4) -- (12,0) -- cycle;

  % 太阳
  \fill[SunYellow] (10,8.5) circle (0.8);

  % 云
  \fill[CloudWhite] (2,8) ellipse (1 and 0.4);
  \fill[CloudWhite] (7,9) ellipse (0.8 and 0.35);

  % 耶稣站在山上
  \fill[CloudWhite] (6,4) -- (5.2,6.5) -- (6.8,6.5) -- cycle; % 白袍
  \fill[SoftPink] (6,6.8) circle (0.45); % 头
  \draw[StarGold, line width=2pt] (6,7.1) circle (0.6); % 光环
  % 张开的手臂
  \draw[SoftPink, line width=4pt] (5.2,5.5) -- (4.5,5.8);
  \draw[SoftPink, line width=4pt] (6.8,5.5) -- (7.5,5.8);

  % 听众 (简化的小圆形代表人群)
  \foreach \x/\y in {2/2.5, 3/3, 4/3.2, 3.5/2, 4.5/2.5, 8/3, 9/2.8, 8.5/2, 9.5/2.5, 10/3} {
    \fill[WarmBrown!60] (\x,\y) circle (0.25);
    \fill[SoftPink] (\x,\y+0.4) circle (0.2);
  }

  % 花朵点缀
  \fill[SoftPink] (1,1.5) circle (0.15);
  \fill[SunYellow] (2,1) circle (0.12);
  \fill[SoftPink] (10,1.8) circle (0.15);
  \fill[SunYellow] (11,1.2) circle (0.12);
\end{tikzpicture}%
}

% 6. 耶稣喂饱五千人 (五饼二鱼)
\newcommand{\fiveloavesscene}{%
\begin{tikzpicture}[scale=1.0]
  % 天空
  \fill[SkyBlue] (0,5) rectangle (12,10);
  % 草地
  \fill[GrassGreen] (0,0) rectangle (12,5);

  % 太阳
  \fill[SunYellow] (2,8) circle (0.7);

  % 云
  \fill[CloudWhite] (7,8.5) ellipse (1.2 and 0.5);
  \fill[CloudWhite] (10,8) ellipse (0.9 and 0.4);

  % 耶稣
  \fill[CloudWhite] (6,2) -- (5.3,4.5) -- (6.7,4.5) -- cycle;
  \fill[SoftPink] (6,4.8) circle (0.4);
  \draw[StarGold, line width=2pt] (6,5.1) circle (0.55);

  % 篮子里的饼和鱼
  \fill[WarmBrown] (5.5,1.8) arc (180:360:0.5) -- cycle; % 篮子
  \fill[SandBeige] (5.6,2) ellipse (0.2 and 0.1); % 饼
  \fill[SandBeige] (5.9,2.1) ellipse (0.2 and 0.1);
  \fill[SandBeige] (6.2,2) ellipse (0.2 and 0.1);
  \fill[WaterBlue!70] (5.7,2.2) ellipse (0.15 and 0.08); % 鱼
  \fill[WaterBlue!70] (6.1,2.25) ellipse (0.15 and 0.08);

  % 人群 (很多小人)
  \foreach \x/\y in {1/1, 2/1.5, 3/1, 2.5/0.5, 1.5/2, 9/1.2, 10/1.5, 11/1, 10.5/0.5, 9.5/2, 3.5/2.5, 8.5/2.3, 4/1.5, 8/1.5} {
    \fill[WarmBrown!50] (\x,\y) circle (0.18);
    \fill[SoftPink] (\x,\y+0.3) circle (0.15);
  }

  % 更多篮子 (表示剩余)
  \fill[WarmBrown] (2,3) arc (180:360:0.3) -- cycle;
  \fill[WarmBrown] (3,3.2) arc (180:360:0.3) -- cycle;
  \fill[WarmBrown] (9,3) arc (180:360:0.3) -- cycle;
  \fill[WarmBrown] (10,3.2) arc (180:360:0.3) -- cycle;
\end{tikzpicture}%
}

% 7. 耶稣爱小孩
\newcommand{\childrenscene}{%
\begin{tikzpicture}[scale=1.0]
  % 背景
  \fill[SkyBlue!50] (0,5) rectangle (12,10);
  \fill[GrassGreen!60] (0,0) rectangle (12,5);

  % 太阳
  \fill[SunYellow] (10,8) circle (0.8);

  % 树
  \fill[WoodBrown] (1,0) rectangle (1.5,3);
  \fill[GrassGreen!80] (1.25,3) circle (1.2);
  \fill[WoodBrown] (10.5,0) rectangle (11,2.5);
  \fill[GrassGreen!80] (10.75,2.5) circle (1);

  % 耶稣坐着
  \fill[CloudWhite] (6,1.5) -- (5,3.5) -- (7,3.5) -- cycle;
  \fill[SoftPink] (6,3.8) circle (0.45);
  \draw[StarGold, line width=2pt] (6,4.1) circle (0.6);
  % 伸出的手臂
  \draw[SoftPink, line width=4pt] (5,3) -- (4,3.3);
  \draw[SoftPink, line width=4pt] (7,3) -- (8,3.3);

  % 小孩子们
  % 左边小孩
  \fill[SoftPink] (3.5,2.5) circle (0.25);
  \fill[HeartRed!60] (3.5,1.5) -- (3.2,2.3) -- (3.8,2.3) -- cycle;

  % 右边小孩
  \fill[SoftPink] (8.5,2.3) circle (0.25);
  \fill[blue!50] (8.5,1.3) -- (8.2,2.1) -- (8.8,2.1) -- cycle;

  % 耶稣身边的小孩
  \fill[SoftPink] (4.5,2.8) circle (0.2);
  \fill[GrassGreen!60] (4.5,2) -- (4.3,2.6) -- (4.7,2.6) -- cycle;

  \fill[SoftPink] (7.5,2.8) circle (0.2);
  \fill[SunYellow!70] (7.5,2) -- (7.3,2.6) -- (7.7,2.6) -- cycle;

  % 花朵
  \fill[SoftPink] (2,1) circle (0.15);
  \fill[SunYellow] (3,0.8) circle (0.12);
  \fill[SoftPink] (9,1.2) circle (0.15);
  \fill[HeartRed!50] (10,0.9) circle (0.12);

  % 爱心
  \fill[HeartRed] (6,5.5) .. controls (6,6) and (5.3,6) .. (5.3,5.5) .. controls (5.3,5) and (6,4.5) .. (6,4.5) .. controls (6,4.5) and (6.7,5) .. (6.7,5.5) .. controls (6.7,6) and (6,6) .. (6,5.5);
\end{tikzpicture}%
}

% 8. 耶稣在十字架上
\newcommand{\crossscene}{%
\begin{tikzpicture}[scale=1.0]
  % 暗色天空
  \fill[NightBlue!70] (0,4) rectangle (12,10);
  % 地面
  \fill[WarmBrown!50] (0,0) rectangle (12,4);

  % 十字架
  \fill[WoodBrown] (5.5,2) rectangle (6.5,8);
  \fill[WoodBrown] (3.5,6) rectangle (8.5,7);

  % 耶稣 (简化)
  \fill[SoftPink] (6,7.5) circle (0.4); % 头
  \fill[CloudWhite] (5.5,4.5) rectangle (6.5,7); % 身体
  % 手臂
  \draw[SoftPink, line width=5pt] (5.5,6.3) -- (3.8,6.3);
  \draw[SoftPink, line width=5pt] (6.5,6.3) -- (8.2,6.3);

  % 光环
  \draw[StarGold, line width=2pt] (6,7.8) circle (0.55);

  % 光芒从十字架发出
  \draw[StarGold, line width=2pt] (6,5) -- (6,10);
  \draw[StarGold, line width=1pt] (4,8) -- (8,8);
  \draw[StarGold, line width=1pt] (4.5,4.5) -- (7.5,9);
  \draw[StarGold, line width=1pt] (7.5,4.5) -- (4.5,9);

  % 小十字架在两边
  \fill[WoodBrown!70] (1.8,2) rectangle (2.2,5);
  \fill[WoodBrown!70] (1,4) rectangle (3,4.4);

  \fill[WoodBrown!70] (9.8,2) rectangle (10.2,5);
  \fill[WoodBrown!70] (9,4) rectangle (11,4.4);

  % 玛利亚 (简化，站在下面)
  \fill[blue!60] (3,0) -- (3,2.5) -- (3.8,3) -- (4,2) -- (3.5,0) -- cycle;
  \fill[SoftPink] (3.4,3.2) circle (0.3);

  % 约翰
  \fill[WarmBrown!70] (8,0) -- (8,2.3) -- (8.8,2.8) -- (9,1.8) -- (8.5,0) -- cycle;
  \fill[SoftPink] (8.4,3) circle (0.3);
\end{tikzpicture}%
}

% 9. 耶稣复活 (空坟墓)
\newcommand{\resurrectionscene}{%
\begin{tikzpicture}[scale=1.0]
  % 日出天空
  \fill[SkyBlue] (0,5) rectangle (12,10);
  \fill[SunYellow!30] (0,5) rectangle (12,7);

  % 太阳升起
  \fill[SunYellow] (6,5) circle (1.5);

  % 草地
  \fill[GrassGreen] (0,0) rectangle (12,5);

  % 山洞/坟墓
  \fill[WarmBrown!80] (3,0) -- (3,5) -- (5,6) -- (9,6) -- (11,5) -- (11,0) -- cycle;
  % 洞口
  \fill[NightBlue!80] (5.5,0) arc (180:0:1.5) -- cycle;
  \fill[NightBlue!80] (5.5,0) rectangle (8.5,3);

  % 滚开的石头
  \fill[gray!60] (9.5,1.5) circle (1);

  % 光芒从洞中发出
  \draw[StarGold, line width=3pt] (7,2) -- (7,7);
  \draw[StarGold, line width=2pt] (5.5,3) -- (4,5);
  \draw[StarGold, line width=2pt] (8.5,3) -- (10,5);

  % 天使
  \fill[CloudWhite] (4,3) -- (3.5,4.5) -- (4.5,4.5) -- cycle;
  \fill[SoftPink] (4,4.7) circle (0.3);

  % 花朵 (象征新生)
  \fill[SoftPink] (1,1.5) circle (0.2);
  \fill[SoftPink] (1.3,1.2) circle (0.18);
  \fill[SunYellow] (2,0.8) circle (0.15);
  \fill[SoftPink] (10,2) circle (0.2);
  \fill[HeartRed!50] (10.5,1.5) circle (0.15);

  % 蝴蝶 (象征重生)
  \fill[SoftPink] (2,4) ellipse (0.3 and 0.15);
  \fill[SoftPink] (1.7,4.2) ellipse (0.15 and 0.2);
  \fill[SoftPink] (2.3,4.2) ellipse (0.15 and 0.2);
\end{tikzpicture}%
}

% 10. 耶稣升天
\newcommand{\ascensionscene}{%
\begin{tikzpicture}[scale=1.0]
  % 天空
  \fill[SkyBlue] (0,4) rectangle (12,10);
  % 草地
  \fill[GrassGreen] (0,0) rectangle (12,4);

  % 云朵
  \fill[CloudWhite] (2,7) ellipse (1.5 and 0.6);
