%% ============================================
%% COMPLETE BIBLICAL CANON STRUCTURE
%% 聖經正典結構
%% ============================================
\newcommand{\biblicalcanon}{%
% scale 1.0: total width 15.3cm fits 15.9cm page width
% OT box: 7.3cm (added 1/2 inch = 1.27cm), NT box: 6cm, gap: 2cm
\begin{tikzpicture}[scale=1.0, transform shape]
  % Old Testament section (width: 7.3cm, x: 0 to 7.3)
  \fill[AdventBlue!15,rounded corners=8pt] (0,0) rectangle (7.3,5.5);
  \draw[AdventBlue,line width=2pt,rounded corners=8pt] (0,0) rectangle (7.3,5.5);
  \node[font={\normalsize\bfseries\cjkfont},color=AdventBlue] at (3.65,4.8) {\cjkfont\upshape\selectfont 舊約 Old Testament (39)};

  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (0.2,4.0) {\cjkfont\upshape\selectfont 律法書 Torah (5): 創出利民申};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (0.2,3.2) {\cjkfont\upshape\selectfont 歷史書 History (12): 書-斯};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (0.2,2.4) {\cjkfont\upshape\selectfont 詩歌智慧 Poetry (5): 伯詩箴傳歌};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (0.2,1.6) {\cjkfont\upshape\selectfont 大先知 Major Prophets (5): 賽耶哀結但};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (0.2,0.8) {\cjkfont\upshape\selectfont 小先知 Minor Prophets (12): 何-瑪};

  % New Testament section (width: 6cm, x: 9.3 to 15.3)
  \fill[JesusRed!15,rounded corners=8pt] (9.3,0) rectangle (15.3,5.5);
  \draw[JesusRed,line width=2pt,rounded corners=8pt] (9.3,0) rectangle (15.3,5.5);
  \node[font={\normalsize\bfseries\cjkfont},color=JesusRed] at (12.3,4.8) {\cjkfont\upshape\selectfont 新約 New Testament (27)};

  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (9.5,4.0) {\cjkfont\upshape\selectfont 福音書 Gospels (4): 太可路約};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (9.5,3.2) {\cjkfont\upshape\selectfont 歷史 History (1): 使徒行傳};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (9.5,2.4) {\cjkfont\upshape\selectfont 保羅書信 Pauline (13): 羅-門};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (9.5,1.6) {\cjkfont\upshape\selectfont 一般書信 General (8): 來-猶};
  \node[font={\small\cjkfont},anchor=west,color=TextGray] at (9.5,0.8) {\cjkfont\upshape\selectfont 預言 Prophecy (1): 啟示錄};

  % Connection arrow (gap: 7.3 to 9.3 = 2cm)
  \draw[->,line width=4pt,LiturgicalGold] (7.3,2.75) -- (9.3,2.75);
  \node[font={\small\bfseries\cjkfont},color=LiturgicalGold] at (8.3,2.0) {\cjkfont\upshape\selectfont 基督};

  % Total (centered at 7.65)
  \node[font={\small\bfseries\cjkfont},color=LiturgicalBlue] at (7.65,-0.6) {\cjkfont\upshape\selectfont 66卷書 · 40+作者 · 1500+年 · 一個故事};
  \node[font={\scriptsize\cjkfont},color=TextGray] at (7.65,-1.1) {66 Books · 40+ Authors · 1500+ Years · One Story};

  % Title (centered at 7.65)
  \node[font={\large\bfseries\cjkfont},color=LiturgicalRed] at (7.65,6.3) {\cjkfont\upshape\selectfont THE HOLY BIBLE 聖經正典};

\end{tikzpicture}
}

