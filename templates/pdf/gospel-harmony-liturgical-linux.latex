  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=LiturgicalBlue,text width=8.5cm] at (0.3,3.3) {\cjkfont\upshape\selectfont 七印七號 Seals \& Trumpets (4-11)};
  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=LiturgicalBlue,text width=8.5cm] at (0.3,2.85) {\cjkfont\upshape\selectfont 龍與獸 Dragon \& Beast (12-14)};
  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=LiturgicalBlue,text width=8.5cm] at (0.3,2.4) {\cjkfont\upshape\selectfont 七碗審判 Seven Bowls (15-16)};
  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=LiturgicalBlue,text width=8.5cm] at (0.3,1.95) {\cjkfont\upshape\selectfont 巴比倫傾覆 Babylon Falls (17-18)};
  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=JesusRed,text width=8.5cm] at (0.3,1.5) {\cjkfont\upshape\selectfont 基督得勝 Christ Victorious (19-20)};
  \node[font={\footnotesize\bfseries\cjkfont},anchor=west,color=LiturgicalGold,text width=8.5cm] at (0.3,1.05) {\cjkfont\upshape\selectfont 新天新地 New Heaven \& Earth (21-22)};

  % Right column - Themes (moved further right to give left column more room)
