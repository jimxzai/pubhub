% ===== CENTRAL CROSS WITH HALO + INRI (upgraded, compact) =====
\begin{tikzpicture}[scale=0.78, transform shape]
  % Halo — outermost soft glow
  \draw[LiturgicalGold, line width=0.3pt, opacity=0.10] (0,1.05) circle (2.30);
  \draw[LiturgicalGold, line width=0.3pt, opacity=0.15] (0,1.05) circle (2.10);
  \draw[LiturgicalGold, line width=0.4pt, opacity=0.22] (0,1.05) circle (1.85);
  \draw[LiturgicalGold, line width=0.5pt, opacity=0.32] (0,1.05) circle (1.55);
  % Dense radiating rays (every 10 degrees for richer effect)
  \foreach \ang in {0,10,20,...,350} {
    \draw[LiturgicalGold, line width=0.35pt, opacity=0.42]
      ({1.05*cos(\ang)}, {1.05+1.05*sin(\ang)}) -- ({1.55*cos(\ang)}, {1.05+1.55*sin(\ang)});
  }
  % Longer "cardinal" rays at compass points
  \foreach \ang in {0,90,180,270} {
    \draw[LiturgicalGold, line width=0.55pt, opacity=0.55]
      ({1.05*cos(\ang)}, {1.05+1.05*sin(\ang)}) -- ({1.80*cos(\ang)}, {1.05+1.80*sin(\ang)});
  }
  % Halo solid inner ring (highlight)
  \draw[LiturgicalGold, line width=1.0pt] (0,1.05) circle (1.05);
  % Halo soft inner glow
  \draw[LiturgicalGold, line width=0.4pt, opacity=0.45] (0,1.05) circle (0.95);

  % INRI plaque (titulus) above the cross — with shadow
  \fill[LiturgicalBlue, opacity=0.20]
    (-0.54,2.53) rectangle (0.56,2.93);  % drop shadow
  \fill[ScriptureBg, draw=LiturgicalGold, line width=0.7pt]
    (-0.55,2.55) rectangle (0.55,2.95);
  \node[font=\tiny\bfseries, color=LiturgicalRed] at (0,2.75) {I.N.R.I.};

  % Cross shadow (subtle depth)
  \fill[LiturgicalBlue, opacity=0.18] (-0.12,-1.84) rectangle (0.14,2.56);
  \fill[LiturgicalBlue, opacity=0.18] (-1.04,1.43) rectangle (1.06,1.69);

  % Vertical beam (tall) — base
  \fill[LiturgicalRed] (-0.13,-1.85) rectangle (0.13,2.55);
  % Vertical beam inner highlight (lighter red strip)
  \fill[LiturgicalRed, opacity=0.55] (-0.05,-1.85) rectangle (0.02,2.55);

  % Horizontal crossbeam — base
  \fill[LiturgicalRed] (-1.05,1.42) rectangle (1.05,1.68);
  % Horizontal beam inner highlight strip
  \fill[LiturgicalRed, opacity=0.55] (-1.05,1.58) rectangle (1.05,1.63);

  % Beam end ornaments — small trefoil tips
  % Top
  \fill[LiturgicalGold] (0,2.55) circle (0.12);
  \fill[LiturgicalGold] (-0.10,2.62) circle (0.06);
  \fill[LiturgicalGold] (0.10,2.62) circle (0.06);
  % Bottom
  \fill[LiturgicalGold] (0,-1.85) circle (0.12);
  \fill[LiturgicalGold] (-0.10,-1.92) circle (0.06);
  \fill[LiturgicalGold] (0.10,-1.92) circle (0.06);
  % Left
  \fill[LiturgicalGold] (-1.05,1.55) circle (0.10);
  \fill[LiturgicalGold] (-1.12,1.45) circle (0.05);
  \fill[LiturgicalGold] (-1.12,1.65) circle (0.05);
  % Right
  \fill[LiturgicalGold] (1.05,1.55) circle (0.10);
  \fill[LiturgicalGold] (1.12,1.45) circle (0.05);
  \fill[LiturgicalGold] (1.12,1.65) circle (0.05);

  % Central jewel where beams cross — 3 layers (gold halo, ruby, highlight)
  \fill[LiturgicalGold] (0,1.55) circle (0.17);
  \fill[LiturgicalRed] (0,1.55) circle (0.10);
  \fill[LiturgicalGold, opacity=0.85] (0,1.58) circle (0.025);
\end{tikzpicture}

