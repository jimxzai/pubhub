%% ============================================
%% APPENDIX I: GREEK & HEBREW GLOSSARY
%% ============================================
\chapter*{Appendix I: Greek \& Hebrew Glossary\\希英重要原文詞彙}
\addcontentsline{toc}{chapter}{Appendix I: Greek \& Hebrew Glossary 希英重要原文詞彙}
\markboth{}{}

\noindent\fcolorbox{LiturgicalGold}{ScriptureBg}{%
\begin{minipage}{6.0in}\vspace{0.18cm}
\centering
{\footnotesize\bfseries\color{LiturgicalRed}\cjkfont\upshape\selectfont 讀經之鑰 \;\textperiodcentered\; The Key}\\[0.4em]
{\footnotesize\color{TextGray}\cjkfont\upshape\selectfont
原文不是給學者炫耀的——是給每個信徒\textit{聽到}耶穌親口說了什麼。\\
中文翻譯有時把不同的希臘字譯成同一個中文字，反之亦然。\\
這些詞，是聖經宇宙的「關鍵字」——認識它們，認識祂深一層。}
\vspace{0.18cm}
\end{minipage}}

\vspace{0.3cm}

\section*{新約希臘語 New Testament Greek}

{\small
\renewcommand{\arraystretch}{1.35}
\begin{longtable}{@{}p{2.2cm}p{2.4cm}p{8.6cm}@{}}
\textbf{原文} & \textbf{Transliteration} & \textbf{含義 \;/\; Meaning} \\
\midrule\endfirsthead
\multicolumn{3}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{原文} & \textbf{Transliteration} & \textbf{含義 \;/\; Meaning} \\
\midrule\endhead
\textbf{λόγος}        & \textit{lógos}        & 道、話語、邏輯。約1:1「太初有道」——神思維、神話語、神位格的綜合。 \\
\textbf{ζωή}          & \textit{zōḗ}          & 生命（神聖的、永恆的）。約1:4「在祂裡面有生命」。不同於 \textit{bios}（生物的）。 \\
\textbf{φῶς}          & \textit{phōs}         & 光。約1:9「真光」——彰顯、揭穿、引導。 \\
\textbf{ἀλήθεια}      & \textit{alḗtheia}     & 真理。原意「無遮蔽」——揭去虛假。約14:6「我就是真理」。 \\
\textbf{χάρις}        & \textit{cháris}       & 恩典——不配得的恩惠、白白的禮物。約1:14「恩典有真理」。 \\
\textbf{ἀγάπη}        & \textit{agápē}        & 愛——犧牲的、無條件的、神聖的愛。約3:16；林前13章。 \\
\textbf{φιλέω}        & \textit{philéō}       & 愛——朋友間情感的愛。約21彼得三問處的對比關鍵。 \\
\textbf{Ἐγώ εἰμι}     & \textit{Egṓ eimi}     & 「我是」——耶穌借用出3:14神的名。約8:58「還沒有亞伯拉罕，就有了我」。 \\
\textbf{σημεῖον}      & \textit{sēmeîon}      & 神蹟、記號——\textit{指向}耶穌身份的指標。約翰福音用此詞，不用 \textit{dynamis}。 \\
\textbf{δύναμις}      & \textit{dýnamis}      & 大能、能力的彰顯。馬可福音用此詞。 \\
\textbf{παράκλητος}   & \textit{paráklētos}   & 保惠師——「來身旁幫助的人」。約14:16聖靈、約壹2:1基督。 \\
\textbf{βαπτίζω}      & \textit{baptízō}      & 浸入、洗禮——浸入水中與基督同死同活（羅6:3-4）。 \\
\textbf{μετάνοια}     & \textit{metánoia}     & 悔改——「思想的轉變」。不只是後悔，是整個方向改變。 \\
\textbf{πίστις}       & \textit{pístis}       & 信心——既是信賴，也是忠信。約3:16「凡信祂的」。 \\
\textbf{δικαιοσύνη}   & \textit{dikaiosýnē}   & 義——神的標準；藉信與基督相連而被算為義（羅3-4）。 \\
\textbf{τετέλεσται}   & \textit{tetélestai}   & 「成了」——商業用詞 \textit{paid in full}。約19:30十架最後一聲。 \\
\textbf{ἀνάστασις}    & \textit{anástasis}    & 復活——「起來、站起」。耶穌的身體不僅醒過來，是進入榮耀身體。 \\
\textbf{παρουσία}     & \textit{parousía}     & 來臨、同在——專指基督再來（太24:3）。 \\
\textbf{εὐαγγέλιον}   & \textit{euaggélion}   & 福音——「好消息」。希臘原意：戰勝的捷報。 \\
\textbf{μυστήριον}    & \textit{mystḗrion}    & 奧祕——神的計劃，過去隱藏，如今在基督裡顯明（弗3）。 \\
\end{longtable}
}

\vspace{0.3cm}

\section*{舊約希伯來語 Old Testament Hebrew}

{\small
\renewcommand{\arraystretch}{1.35}
\begin{longtable}{@{}p{2.2cm}p{2.4cm}p{8.6cm}@{}}
\textbf{原文} & \textbf{Transliteration} & \textbf{含義 \;/\; Meaning} \\
\midrule\endfirsthead
\multicolumn{3}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{原文} & \textbf{Transliteration} & \textbf{含義 \;/\; Meaning} \\
\midrule\endhead
\textbf{יהוה}         & \textit{YHWH}         & 耶和華——神向摩西啟示的聖名（出3:14）。猶太人不敢直呼，讀作\textit{Adonai}。 \\
\textbf{אֱלֹהִים}      & \textit{Elohim}       & 神——複數形式單數動詞，預表三位一體（創1:1）。 \\
\textbf{אָדוֹן}        & \textit{Adon/Adonai}  & 主——「擁有者、主宰」。 \\
\textbf{מָשִׁיחַ}      & \textit{Mashiach}     & 彌賽亞——「受膏者」。希臘文譯作 \textit{Christos}（基督）。 \\
\textbf{בְּרִית}       & \textit{Berit}        & 約——神主動立的盟約：與亞伯拉罕、摩西、大衛，最終在基督裡成全新約。 \\
\textbf{חֶסֶד}         & \textit{Hesed}        & 慈愛、信實的愛——神立約的不離不棄之愛。詩136篇「祂的慈愛永遠長存」。 \\
\textbf{אֱמֶת}         & \textit{Emet}         & 真實、信實——神的話可靠不變。新約 \textit{alētheia} 的舊約根。 \\
\textbf{שָׁלוֹם}       & \textit{Shalom}       & 平安——不只無爭，是\textit{完整、興盛、與神和好}的整全狀態。 \\
\textbf{תּוֹרָה}       & \textit{Torah}        & 律法、教導——摩西五經；指神的訓誨而非僅戒條。 \\
\textbf{קָדוֹשׁ}       & \textit{Qadosh}       & 聖——「分別出來」。神是聖的（賽6:3），我們被分別歸祂。 \\
\textbf{רוּחַ}         & \textit{Ruach}        & 靈、風、氣息——神的靈運行在水面上（創1:2）。新約 \textit{pneuma}。 \\
\textbf{נֶפֶשׁ}        & \textit{Nephesh}      & 魂、生命——人成了\textit{有靈的活人}（創2:7）。 \\
\textbf{הוֹשַׁע נָא}   & \textit{Hoshia-na}    & 「求祢拯救」——希臘文轉為 \textit{Hosanna}「和散那」（太21:9）。 \\
\textbf{אָמֵן}         & \textit{Amen}         & 阿們——「實在的、可信的、就這樣成就」。耶穌自稱「那位阿們的」（啟3:14）。 \\
\textbf{הַלְלוּיָהּ}    & \textit{Hallelu-Yah}  & 哈利路亞——「你們要讚美耶和華」。詩篇150篇末句。 \\
\textbf{עִמָּנוּאֵל}    & \textit{Immanu-El}    & 以馬內利——「神與我們同在」（賽7:14；太1:23）。 \\
\end{longtable}
}

\vspace{0.3cm}

\noindent\textbf{帶領提問 Leading Question}\\[0.2em]
\textit{學原文不是炫耀知識——是把耶穌親口說的話聽得更清楚。\\
這20多個詞中，哪一個今天感動你？\\
Of these 20+ words, which one moves you today?}

\pagebreak

%% ============================================
%% APPENDIX J: 60-DAY READING PLAN
%% ============================================
\chapter*{Appendix J: 60-Day Reading Plan\\六十日讀經計劃}
\addcontentsline{toc}{chapter}{Appendix J: 60-Day Reading Plan 六十日讀經計劃}
\markboth{}{}

\noindent\fcolorbox{LiturgicalGold}{ScriptureBg}{%
\begin{minipage}{6.0in}\vspace{0.18cm}
\centering
{\footnotesize\bfseries\color{LiturgicalRed}\cjkfont\upshape\selectfont 讀經之鑰 \;\textperiodcentered\; The Key}\\[0.4em]
{\footnotesize\color{TextGray}\cjkfont\upshape\selectfont
60天，37章，每日 8-12 頁——一杯咖啡的時間。\\
重要的不是\textit{讀完}，是\textit{遇見}。\\
若某一日的話打中你——\textbf{停下來，在那裡住一天}。}
\vspace{0.18cm}
\end{minipage}}

\vspace{0.3cm}

\noindent\textit{此計劃以禮儀年週期分配，重點章節（受難週、復活、十架）給予兩天反芻時間。
This plan follows the liturgical year; Passion Week chapters receive double days for meditation.}

\vspace{0.4cm}

\section*{第一階段：道成肉身 \;\textperiodcentered\; Days 1-10 (Advent \& Christmastide)}

{\small
\renewcommand{\arraystretch}{1.20}
\begin{longtable}{@{}p{1.3cm}p{3.7cm}p{2.0cm}p{6.0cm}@{}}
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句 \;/\; Meditate} \\
\midrule\endfirsthead
\multicolumn{4}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句 \;/\; Meditate} \\
\midrule\endhead
1  & 序 太初有道 Prologue           & 約1:1-18     & 「道成了肉身，住在我們中間。」 \\
2  & 1 天使報喜 Annunciation        & 路1          & 「在神沒有一件不能的事。」 \\
3  & 2 伯利恆之夜 Bethlehem         & 路2          & 「客店裡沒有地方。」（你心裡呢？） \\
4  & 3 童年歲月 Childhood            & 路2:41-52   & 「以我父的事為念。」 \\
5  & 4 曠野預備 Wilderness            & 太4          & 「人活著不是單靠食物。」 \\
6  & 5 首批門徒 First Disciples      & 約1:35-51   & 「拿但業，我看見你了。」 \\
7  & 6 迦拿婚宴 Cana                 & 約2          & 真葡萄樹宣告——好酒留到最後。 \\
8  & 7 潔淨聖殿 Temple Cleansing I   & 約2          & 「我父的殿是禱告的殿。」 \\
9  & 8 尼哥底母 Nicodemus            & 約3          & 「人若不重生，就不能見神的國。」 \\
10 & 9 撒瑪利亞婦人 Samaritan        & 約4          & 你心裡那口井叫什麼名字？ \\
\end{longtable}
}

\section*{第二階段：公開事工 \;\textperiodcentered\; Days 11-30 (Ordinary Time)}

{\small
\renewcommand{\arraystretch}{1.20}
\begin{longtable}{@{}p{1.3cm}p{3.7cm}p{2.0cm}p{6.0cm}@{}}
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endfirsthead
\multicolumn{4}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endhead
11 & 10 醫治神蹟 Healing            & 太8-9        & 問題不在「能不能」，在你「要不要」。 \\
12 & 11 山上寶訓 上 Sermon I        & 太5          & 八福：基督生命的寫照。 \\
13 & 11 山上寶訓 下 Sermon II       & 太6-7        & 「你的財寶在哪裡，你的心也在哪裡。」 \\
14 & 12 五餅二魚 Feeding 5000       & 約6:1-14    & 你手裡的五餅二魚是什麼？ \\
15 & 13 海面行走 Walking on Water   & 約6:15-21   & Ἐγώ εἰμι——「我是」。 \\
16 & 14 生命的糧 Bread of Life      & 約6:22-71   & 不是「給」糧，祂\textit{就是}糧。 \\
17 & 15 住棚節 Feast Tabernacles    & 約7-8       & 「人若渴了，可以到我這裡來喝。」 \\
18 & 16 醫治瞎眼 Blind Man         & 約9          & 全章誰是瞎子？答案是所有人。 \\
19 & 17 好牧人 Good Shepherd        & 約10         & 「我的羊聽我的聲音。」 \\
20 & 18 拉撒路復活 Lazarus          & 約11         & 「復活在我，生命也在我。」 \\
21 & 19 天國比喻 上 Parables I     & 太13         & 天國的奧祕——向自高隱藏。 \\
22 & 19 天國比喻 下 Parables II    & 路15         & 三位一體都在尋找你。 \\
23 & 20 財主與天國 Rich Ruler       & 太19         & 他憂憂愁愁地走了——耶穌沒有改變祂的話。 \\
24 & 21 登山變像 Transfiguration    & 太17         & 神不要「也包括耶穌」，要「唯獨耶穌」。 \\
25 & 22 榮耀進城 Triumphal Entry    & 太21         & 撒迦利亞9:9寫了五百年的劇本。 \\
26 & 23 潔淨聖殿 II Temple II      & 太21         & 同一件事——三年後再做一次。 \\
27 & 24 橄欖山講論 Olivet           & 太24-25     & 命令不是「計算」，是「儆醒」。 \\
28 & 25 最後晚餐 Last Supper        & 太26         & 祂明知道猶大的腳，照樣洗了。 \\
29 & 26 馬可樓講論 Upper Room      & 約13-17     & 約16:28 —— 24個字的整本福音書。 \\
30 & 27 大祭司禱告 High Priestly    & 約17         & 在被賣同夜，禱告「合而為一」。 \\
\end{longtable}
}

\pagebreak

\section*{第三階段：受難復活 \;\textperiodcentered\; Days 31-50 (Lent \& Easter — double days)}

{\small
\renewcommand{\arraystretch}{1.20}
\begin{longtable}{@{}p{1.3cm}p{3.7cm}p{2.0cm}p{6.0cm}@{}}
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endfirsthead
\multicolumn{4}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endhead
31 & 28 客西馬尼園 Gethsemane I    & 太26:36-46  & 第一亞當：「隨自己的意思」。 \\
32 & 28 客西馬尼園 Gethsemane II   & 太26:36-46  & 末後亞當：「照你的意思」。 \\
33 & 29 審判 Trial I               & 太26:57+    & 祂沉默不是無話，是不必再說。 \\
34 & 29 審判 Trial II              & 太27:11+    & 被審判的是聽審者。 \\
35 & 30 釘十字架 Crucifixion I     & 太27        & τετέλεσται —— paid in full. \\
36 & 30 架上七言 Seven Sayings     & 太27/路23   & 父啊赦免他們 \;\textbullet\; 你今日同我在樂園 \\
37 & 30 架上七言（續）             & 約19/太27   & 看你的母 \;\textbullet\; 我的神我的神 \\
38 & 30 架上七言（續）             & 約19/路23   & 我渴了 \;\textbullet\; 成了 \;\textbullet\; 父啊我將靈魂交在祢手 \\
39 & 31 埋葬 Burial                & 約19:38-42  & 十字架顯出隱藏的信徒。 \\
40 & 31 安息日 The Silent Sabbath  & --          & 那看不見動靜的一天——\textit{安息}。 \\
41 & 32 復活 Resurrection I        & 約20:1-10   & 封條從外面封進去，從裡面打開出來。 \\
42 & 32 復活 Resurrection II       & 約20:11-18  & 「馬利亞」——叫名字的聲音。 \\
43 & 33 復活顯現 Appearances I     & 路24:13-35  & 以馬忤斯路上——擘餅那一刻。 \\
44 & 33 復活顯現 II                & 約20:19-29  & 「我的主！我的神！」 \\
45 & 33 復活顯現 III               & 約21        & 「彼得，你愛我比這些更深嗎？」 \\
46 & 34 升天與使命 Ascension       & 徒1:1-11   & 「你們仰望天作什麼？去吧。」 \\
47 & 35 五旬節 Pentecost           & 徒2          & 收割節——第一批莊稼。 \\
48 & 36 七教會的信 Letters I       & 啟2:1-17    & 以弗所、士每拿、別迦摩 \\
49 & 36 七教會的信 II              & 啟2:18-29   & 推雅推喇 \\
50 & 36 七教會的信 III             & 啟3          & 撒狄、非拉鐵非、老底嘉 \\
\end{longtable}
}

\section*{第四階段：榮耀再臨 \;\textperiodcentered\; Days 51-60 (Reign of Christ)}

{\small
\renewcommand{\arraystretch}{1.20}
\begin{longtable}{@{}p{1.3cm}p{3.7cm}p{2.0cm}p{6.0cm}@{}}
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endfirsthead
\multicolumn{4}{@{}l}{\small\itshape\color{TextGray}（接上頁 / continued）}\\[0.2em]
\textbf{Day} & \textbf{Chapter} & \textbf{Ref} & \textbf{反芻句} \\
\midrule\endhead
51 & 37 榮耀再臨 Glorious Return I  & 啟19         & 那騎白馬的，名字叫神之道。 \\
52 & 37 新天新地 New Heavens       & 啟21         & 「神的帳幕在人間，祂要與人同住。」 \\
53 & 37 生命河 River of Life       & 啟22:1-5    & 「再沒有黑夜……主神要光照他們。」 \\
54 & 37 最後的呼召 Last Call       & 啟22:6-21   & 「主耶穌啊，我願祢來！」 \\
55 & 跋 Coda                         & --          & 給合上書的你。 \\
56-58 & 重讀 Re-reading             & --          & 從第1章再讀一遍——這次，把主角放回正確位子。 \\
59 & 默想：架上七言整段             & --          & 七言一氣呵成，讓它住在你裡面。 \\
60 & 默想：約16:28 整本書綱要      & --          & 「我從父出來……往父那裡去。」 \\
\end{longtable}
}

\vspace{0.3cm}

\noindent\textbf{帶領提問 Leading Question}\\[0.2em]
\textit{60天後，再回頭問自己一次：\\
我是\textit{讀完}了這本書，還是\textit{遇見}了書中的那位主？\\
After 60 days, ask yourself again:\\
Did I just finish a book, or did I meet the Person within it?}

