\makeoddfoot{plain}{}{\Large\thepage}{}

%% ============================================
%% BLOCKQUOTE STYLING
%% ============================================
\renewenvironment{quote}{%
  \par\vspace{0.5\baselineskip}%
  \list{}{%
    \leftmargin=0.8em
    \rightmargin=0.4em
    \parsep=0pt
    \itemsep=0pt
  }%
  \item\relax
  \large\color{TextGray}%
}{%
  \endlist
  \par\vspace{0.5\baselineskip}%
}

%% ============================================
%% WIDOW/ORPHAN AND LINE BREAKING
%% ============================================
\widowpenalty=10000
\clubpenalty=10000
\tolerance=9999
\emergencystretch=6em
\hyphenpenalty=50
\exhyphenpenalty=50
\sloppy
\hbadness=10000
\hfuzz=2pt

%% ============================================
%% METADATA
%% ============================================
$if(title)$
\title{$title$}
$endif$
$if(author)$
\author{$author$}
$endif$
$if(date)$
\date{$date$}
$endif$

