%% ============================================
%% MEMOIR CHAPTER STYLE - LITURGICAL
%% ============================================
\makechapterstyle{liturgical}{%
  \chapterstyle{default}
  \renewcommand*{\chapnamefont}{\normalfont\Large\scshape\color{LiturgicalBlue}}
  \renewcommand*{\chapnumfont}{\normalfont\fontsize{48}{52}\selectfont\bfseries\color{LiturgicalRed}}
  \renewcommand*{\chaptitlefont}{\normalfont\LARGE\bfseries\color{LiturgicalBlue}}
  \renewcommand*{\printchaptername}{\centering\chapnamefont Chapter}
  \renewcommand*{\printchapternum}{\centering\chapnumfont \thechapter}
  \renewcommand*{\printchaptertitle}[1]{%
    \centering\chaptitlefont ##1\par
    \vskip 10pt
    {\color{LiturgicalGold}\rule{4in}{2pt}}
  }
  \setlength{\beforechapskip}{60pt}
  \setlength{\afterchapskip}{40pt}
}
\chapterstyle{liturgical}

%% ============================================
%% SECTION STYLING
%% ============================================
\setsecheadstyle{\normalfont\Large\bfseries\color{LiturgicalBlue}}
\setsubsecheadstyle{\normalfont\large\bfseries\color{TextGray}}
\setsubsubsecheadstyle{\normalfont\normalsize\bfseries\color{TextGray}}

%% ============================================
%% HEADERS AND FOOTERS
%% ============================================
\makepagestyle{liturgical}
\makeevenhead{liturgical}{\Large\thepage}{}{\large\scshape\color{LightGray}\leftmark}
\makeoddhead{liturgical}{\large\scshape\color{LightGray}\rightmark}{}{\Large\thepage}
\makeheadrule{liturgical}{\textwidth}{1pt}
\makeevenfoot{liturgical}{}{}{}
\makeoddfoot{liturgical}{}{}{}
\pagestyle{liturgical}

