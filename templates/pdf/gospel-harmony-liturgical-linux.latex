% Source-citation box — distinguishing biblical roots from church tradition
\noindent\fcolorbox{LiturgicalGold}{ScriptureBg}{%
\begin{minipage}{5.6in}\vspace{0.18cm}
\centering
{\footnotesize\bfseries\color{LiturgicalRed}\cjkfont\upshape\selectfont
這從哪裡來？\;\textperiodcentered\; Where Does This Come From?}\\[0.4em]

\begin{minipage}{2.55in}
\raggedright\footnotesize\color{TextGray}\cjkfont\upshape\selectfont
{\bfseries\color{JesusRed}\textcolor{JesusRed}{\checkmark}\;聖經根 Biblical Roots}\\[0.2em]
\textbullet\ \textbf{詩 119:164}：「一天七次讚美祢」\\
\textbullet\ \textbf{詩 55:17}：「晚上、早晨、晌午」\\
\textbullet\ \textbf{但 6:10}：但以理一日三次禱告\\
\textbullet\ \textbf{徒 3:1; 10:9}：使徒在固定時辰禱告
\end{minipage}\hfill
\begin{minipage}{2.55in}
\raggedright\footnotesize\color{TextGray}\cjkfont\upshape\selectfont
{\bfseries\color{LiturgicalBlue}\textcolor{LiturgicalBlue}{\checkmark}\;教會傳統 Church Tradition}\\[0.2em]
\textbullet\ \textit{Didache}（2世紀）：日三次\\
\textbullet\ Egeria 朝聖記（4世紀）\\
\textbullet\ 本篤《會規》（6世紀）：八時禱告\\
\textbullet\ 公禱書（1549）：晨禱+晚禱
\end{minipage}

\vspace{0.35em}
{\footnotesize\itshape\color{TextGray}\cjkfont\upshape\selectfont
「固定時辰禱告」是聖經的；\textit{具體編排（八時/七時/兩時）是教會歷史的有益形式。}}
\vspace{0.18cm}
\end{minipage}}

\end{center}
\cleardoublepage

