\textcolor{LiturgicalBlue}{\rule{\linewidth}{0.5pt}}\\[0.3em]
{\cjkfont\small\bfseries\color{JesusRed} 徒 1:8 關鍵經文 Key Verse:}\\[0.2em]
{\cjkfont\small\color{TextGray} 「但聖靈降臨在你們身上，你們就必得著能力，並要在耶路撒冷、猶太全地和撒瑪利亞，直到地極，作我的見證。」}\\[0.5em]
\textcolor{LiturgicalGold}{\hrule height 0.4pt}
\vspace{0.4em}

\noindent\begin{minipage}[t]{0.48\linewidth}
{\cjkfont\footnotesize\bfseries\color{LiturgicalBlue} 結構 Structure:}\\
{\cjkfont\footnotesize\color{TextGray} 1-7章: 耶路撒冷 Jerusalem}\\
{\cjkfont\footnotesize\color{TextGray} 8-12章: 猶太和撒瑪利亞 Judea \& Samaria}\\
{\cjkfont\footnotesize\color{TextGray} 13-28章: 地極 Ends of the Earth}
\end{minipage}\hfill
\begin{minipage}[t]{0.48\linewidth}
{\cjkfont\footnotesize\bfseries\color{LiturgicalBlue} 主題 Themes:}\\
{\cjkfont\footnotesize\color{TextGray} 聖靈能力 Power of Spirit}\\
{\cjkfont\footnotesize\color{TextGray} 福音擴展 Gospel Expansion}\\
{\cjkfont\footnotesize\color{TextGray} 教會建立 Church Planting}
\end{minipage}\\[0.5em]

\begin{center}
{\cjkfont\scriptsize\color{LightGray} 路加福音的續篇 --- 從基督升天到保羅在羅馬}
\end{center}
\vspace{0.2cm}
\end{minipage}%
}
\end{center}
}

