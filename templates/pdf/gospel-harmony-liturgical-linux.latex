%% ============================================
%% HOLY LAND MAP (Gospel Harmony Locations) - FULL PAGE SIZE
%% ============================================
\newcommand{\holylandmap}{%
% scale 1.0: width 15cm fits 15.9cm page, reduced internal width, smaller fonts
\begin{tikzpicture}[scale=1.0]
  % Background - Land (width 15cm to fit page)
  \fill[LandBeige] (0,0) rectangle (15,14);

  % Mediterranean Sea (left strip)
  \fill[WaterBlue] (0,0) rectangle (2.5,14);
  \draw[SeaDark,line width=1pt] (2.5,0) -- (2.5,14);
  \node[font={\small\cjkfont},color=LiturgicalBlue,rotate=90] at (1.25,7) {\cjkfont\upshape\selectfont Mediterranean Sea 地中海};

  % Sea of Galilee
  \fill[WaterBlue] (10,11) ellipse (1.4 and 1.6);
  \draw[SeaDark,line width=0.8pt] (10,11) ellipse (1.4 and 1.6);
  \node[font={\small\cjkfont},color=SeaDark] at (10,11.3) {Sea of Galilee};
  \node[font={\small\cjkfont},color=SeaDark] at (10,10.6) {\cjkfont\upshape\selectfont 加利利海};

  % Jordan River
  \draw[WaterBlue,line width=3pt] (10,9.4)
    .. controls (9.5,8) and (10,7) .. (9.7,6)
    .. controls (9.4,5) and (9.8,4) .. (9.5,3)
    .. controls (9.3,2) and (9.6,1.5) .. (9.5,1);
  \node[font={\small\cjkfont},color=SeaDark,rotate=-70] at (10.5,6.5) {\cjkfont\upshape\selectfont Jordan 約旦河};

  % Dead Sea
  \fill[WaterBlue!70!SeaDark] (9.5,0.8) ellipse (1.0 and 1.1);
  \draw[SeaDark,line width=0.8pt] (9.5,0.8) ellipse (1.0 and 1.1);
  \node[font={\small\cjkfont},color=white] at (9.5,1) {Dead Sea};
  \node[font={\small\cjkfont},color=white] at (9.5,0.5) {\cjkfont\upshape\selectfont 死海};

  % ========== KEY LOCATIONS FOR GOSPEL HARMONY ==========

  % Nazareth - Childhood (top left area)
  \fill[LiturgicalGold] (5,12) circle (0.2);
  \draw[LiturgicalGold,line width=1pt] (5,12) circle (0.32);
  \node[font={\normalsize\bfseries\cjkfont},left,color=LiturgicalBlue] at (4.6,12) {\cjkfont\upshape\selectfont Nazareth 拿撒勒};
  \node[font={\small\cjkfont},left,color=TextGray] at (4.6,11.5) {\cjkfont\upshape\selectfont Childhood 童年};

  % Cana (between Nazareth and Capernaum)
  \fill[LiturgicalGold] (7,12.8) circle (0.16);
  \node[font={\small\cjkfont},above,color=TextGray] at (7,13) {\cjkfont\upshape\selectfont Cana 迦拿};

  % Capernaum - Ministry Base (near Sea of Galilee)
  \fill[LiturgicalGold] (12,12) circle (0.2);
  \draw[LiturgicalGold,line width=1pt] (12,12) circle (0.32);
  \node[font={\normalsize\bfseries\cjkfont},right,color=LiturgicalBlue] at (12.4,12) {Capernaum};
  \node[font={\small\cjkfont},right,color=TextGray] at (12.4,11.5) {\cjkfont\upshape\selectfont 迦百農};

  % Sychar (Samaria) - mid region
  \fill[LiturgicalGold] (5.5,7.5) circle (0.16);
  \node[font={\small\cjkfont},left,color=TextGray] at (5.2,7.5) {\cjkfont\upshape\selectfont Sychar 敘加};
  \node[font={\scriptsize\cjkfont},left,color=TextGray] at (5.2,7) {Samaritan Woman};

  % JERUSALEM - Central focus (prominent)
  \fill[JesusRed] (6.5,4.5) circle (0.28);
  \draw[JesusRed,line width=2pt] (6.5,4.5) circle (0.45);
  \node[font={\large\bfseries\cjkfont},left,color=JesusRed] at (6,4.5) {JERUSALEM};
  \node[font={\normalsize\cjkfont},left,color=JesusRed] at (6,3.9) {\cjkfont\upshape\selectfont 耶路撒冷};

  % Golgotha cross near Jerusalem
  \node[font={\large\cjkfont},color=JesusRed] at (7.8,4.8) {\ensuremath{\dagger}};

  % Bethlehem - Birth (south of Jerusalem)
  \fill[LiturgicalGold] (5.8,2.8) circle (0.2);
  \draw[LiturgicalGold,line width=1pt] (5.8,2.8) circle (0.32);
  \node[font={\normalsize\bfseries\cjkfont},left,color=LiturgicalBlue] at (5.4,2.8) {\cjkfont\upshape\selectfont Bethlehem 伯利恆};
  \node[font={\small\cjkfont},left,color=TextGray] at (5.4,2.3) {\cjkfont\upshape\selectfont Birth of Jesus 主降生};

  % Bethany (east of Jerusalem)
  \fill[LiturgicalGold] (11.5,4.5) circle (0.16);
  \node[font={\small\cjkfont},right,color=TextGray] at (11.8,4.5) {\cjkfont\upshape\selectfont Bethany 伯大尼};

  % Jericho (on the way to Jerusalem)
  \fill[LiturgicalGold] (11,6) circle (0.14);
  \node[font={\small\cjkfont},right,color=TextGray] at (11.3,6) {\cjkfont\upshape\selectfont Jericho 耶利哥};

  % ========== COMPASS ==========
  \draw[->,very thick,color=LiturgicalBlue] (14,13) -- (14,13.7);
  \node[font={\normalsize\bfseries\cjkfont},color=LiturgicalBlue] at (14,13.9) {N};

  % ========== SCALE ==========
  \draw[very thick,color=TextGray] (5,0.3) -- (9,0.3);
  \draw[thick,color=TextGray] (5,0.1) -- (5,0.5);
  \draw[thick,color=TextGray] (9,0.1) -- (9,0.5);
  \node[font={\small\cjkfont},color=TextGray] at (7,-0.1) {50 km / 30 miles};

  % ========== LEGEND ==========
  \fill[ScriptureBg,rounded corners=5pt] (0.2,12.8) rectangle (4.5,14);
  \draw[LiturgicalGold,line width=1pt,rounded corners=5pt] (0.2,12.8) rectangle (4.5,14);
  \node[font={\small\bfseries\cjkfont},color=LiturgicalBlue] at (2.35,13.7) {\cjkfont\upshape\selectfont Legend 圖例};
  \fill[JesusRed] (0.5,13.3) circle (0.1);
  \node[font={\scriptsize\cjkfont},right,color=TextGray] at (0.75,13.3) {\cjkfont\upshape\selectfont Jerusalem 聖城};
  \fill[LiturgicalGold] (0.5,12.95) circle (0.08);
  \node[font={\scriptsize\cjkfont},right,color=TextGray] at (0.75,12.95) {\cjkfont\upshape\selectfont Key Location 重要地點};
\end{tikzpicture}%
}

%% ============================================
%% EUCHARISTIC PRAYER STRUCTURE
%% ============================================
\newcommand{\eucharisticstructure}{%
\begin{tikzpicture}[scale=1.0, transform shape]
  % Main structure
  \node[rectangle, draw=LiturgicalRed, fill=LiturgicalRed!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (sursum) at (0,6) {Sursum Corda 舉心向上};

  \node[rectangle, draw=LiturgicalGold, fill=LiturgicalGold!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (preface) at (0,5) {Preface 頌謝文};

  \node[rectangle, draw=LiturgicalRed, fill=LiturgicalRed!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (sanctus) at (0,4) {Sanctus 聖哉頌};

  \node[rectangle, draw=LiturgicalBlue, fill=LiturgicalBlue!20,
        minimum width=5cm, minimum height=1.2cm, font={\small\bfseries\cjkfont},
        text width=4.5cm, align=center]
        (eucharist) at (0,2.7) {Eucharistic Prayer\\感恩經};

  \node[rectangle, draw=LiturgicalRed, fill=LiturgicalRed!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (mystery) at (0,1.4) {Mystery of Faith 信德奧蹟};

  \node[rectangle, draw=LiturgicalGold, fill=LiturgicalGold!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (doxology) at (0,0.4) {Great Doxology 光榮頌};

  \node[rectangle, draw=LiturgicalRed, fill=LiturgicalRed!20,
        minimum width=5cm, minimum height=0.8cm, font={\small\bfseries\cjkfont}]
        (amen) at (0,-0.6) {Great Amen 阿們};

  % Connecting lines
  \draw[line width=1pt, gray] (sursum) -- (preface);
  \draw[line width=1pt, gray] (preface) -- (sanctus);
  \draw[line width=1pt, gray] (sanctus) -- (eucharist);
  \draw[line width=1pt, gray] (eucharist) -- (mystery);
  \draw[line width=1pt, gray] (mystery) -- (doxology);
  \draw[line width=1pt, gray] (doxology) -- (amen);

  % Labels
  \node[font={\tiny\cjkfont}, right] at (2.8,6) {``Lift up your hearts''};
  \node[font={\tiny\cjkfont}, right] at (2.8,5) {Proper to season};
  \node[font={\tiny\cjkfont}, right] at (2.8,4) {``Holy, Holy, Holy''};
  \node[font={\tiny\cjkfont}, right] at (2.8,2.7) {``This is my Body...''};
  \node[font={\tiny\cjkfont}, right] at (2.8,1.4) {``Christ has died...''};
  \node[font={\tiny\cjkfont}, right] at (2.8,0.4) {``Through him...''};
  \node[font={\tiny\cjkfont}, right] at (2.8,-0.6) {People's Amen};

  % Title
  \node[font={\normalsize\bfseries\cjkfont}, text=LiturgicalRed] at (0,7.2) {\cjkfont\upshape\selectfont EUCHARISTIC PRAYER 感恩經結構};

\end{tikzpicture}
}

%% ============================================
%% SALVATION HISTORY TIMELINE
%% 神救贖計劃與人類歷史時間軸
%% ============================================
\newcommand{\salvationtimeline}{%
% scale 0.95: width 15cm × 0.95 = 14.25cm fits 15.9cm page safely
\begin{tikzpicture}[scale=0.95, transform shape]
  % Main timeline axis
  \draw[line width=2pt, LiturgicalGold] (-0.5,0) -- (15,0);

  % Era backgrounds
  \fill[AdventBlue!20] (0,-1.8) rectangle (2.5,1.8);
  \fill[OrdinaryGreen!20] (2.5,-1.8) rectangle (5.5,1.8);
  \fill[LentPurple!20] (5.5,-1.8) rectangle (8,1.8);
  \fill[JesusRed!20] (8,-1.8) rectangle (10.5,1.8);
  \fill[EasterWhite] (10.5,-1.8) rectangle (13,1.8);
  \fill[LiturgicalGold!30] (13,-1.8) rectangle (15,1.8);

  % Timeline markers
  \foreach \x/\year/\event/\eventzh in {
    0/{創造 Creation}/{4000 BC}/{亞當},
    1.5/{洪水 Flood}/{2400 BC}/{挪亞},
    2.5/{亞伯拉罕}/{2000 BC}/{Abraham},
    4/{摩西 Moses}/{1500 BC}/{出埃及},
    5.5/{大衛 David}/{1000 BC}/{王國},
    7/{被擄 Exile}/{586 BC}/{巴比倫},
    8/{基督降生}/{4 BC}/{Incarnation},
    9.5/{十架復活}/{AD 30}/{Cross},
    10.5/{教會時代}/{AD 30-?}/{Church Age},
    13/{基督再來}/{?}/{Second Coming},
    14.5/{新天新地}/{永恆}/{Eternity}
  } {
    \fill[LiturgicalRed] (\x,0) circle (0.12);
    \node[font={\tiny\cjkfont}, above, text width=1.3cm, align=center] at (\x,0.3) {\event};
    \node[font={\tiny\cjkfont}, below, color=LightGray] at (\x,-0.3) {\year};
  }

  % Era labels
  \node[font={\footnotesize\bfseries\cjkfont}, color=AdventBlue] at (1.25,1.5) {\cjkfont\upshape\selectfont 創造與墮落};
  \node[font={\tiny\cjkfont}, color=AdventBlue] at (1.25,1.1) {Creation \& Fall};

  \node[font={\footnotesize\bfseries\cjkfont}, color=OrdinaryGreen!80!black] at (4,1.5) {\cjkfont\upshape\selectfont 族長與律法};
  \node[font={\tiny\cjkfont}, color=OrdinaryGreen!80!black] at (4,1.1) {Patriarchs \& Law};

  \node[font={\footnotesize\bfseries\cjkfont}, color=LentPurple] at (6.75,1.5) {\cjkfont\upshape\selectfont 王國與先知};
  \node[font={\tiny\cjkfont}, color=LentPurple] at (6.75,1.1) {Kingdom \& Prophets};

  \node[font={\footnotesize\bfseries\cjkfont}, color=JesusRed] at (9.25,1.5) {\cjkfont\upshape\selectfont 道成肉身};
  \node[font={\tiny\cjkfont}, color=JesusRed] at (9.25,1.1) {Incarnation};

  \node[font={\footnotesize\bfseries\cjkfont}, color=LiturgicalBlue] at (11.75,1.5) {\cjkfont\upshape\selectfont 教會時代};
  \node[font={\tiny\cjkfont}, color=LiturgicalBlue] at (11.75,1.1) {Church Age};

  \node[font={\footnotesize\bfseries\cjkfont}, color=LiturgicalGold] at (14,1.5) {\cjkfont\upshape\selectfont 永恆國度};
  \node[font={\tiny\cjkfont}, color=LiturgicalGold] at (14,1.1) {Eternal Kingdom};

  % Title
  \node[font={\normalsize\bfseries\cjkfont}, color=LiturgicalRed] at (7.5,-2.5) {\cjkfont\upshape\selectfont GOD'S SALVATION HISTORY 神救贖歷史時間軸};

  % Key scripture references
  \node[font={\tiny\cjkfont}, color=TextGray, text width=14cm, align=center] at (7.5,-3.2)
    {\cjkfont\upshape\selectfont 創1:1 創造 → 創3 墮落 → 創12 亞伯拉罕之約 → 出20 律法 → 撒下7 大衛之約 → 賽53 受苦僕人 → 約1:14 道成肉身 → 徒2 五旬節 → 啟21 新天新地};

\end{tikzpicture}
}

%% ============================================
%% FIVE-ACT BIBLICAL DRAMA
%% 聖經五幕劇結構
%% ============================================
\newcommand{\fiveactdrama}{%
\begin{tikzpicture}[scale=1.0, transform shape]
  % Act boxes
  \node[rectangle, draw=LiturgicalGold, fill=LiturgicalGold!20,
        minimum width=2.2cm, minimum height=1.5cm, font={\small\bfseries\cjkfont},
        rounded corners=5pt, text width=2cm, align=center] (act1) at (0,0) {Act I\\創造};

  \node[rectangle, draw=JesusRed, fill=JesusRed!15,
        minimum width=2.2cm, minimum height=1.5cm, font={\small\bfseries\cjkfont},
        rounded corners=5pt, text width=2cm, align=center] (act2) at (3,0) {Act II\\墮落};

  \node[rectangle, draw=LiturgicalBlue, fill=LiturgicalBlue!15,
        minimum width=2.2cm, minimum height=1.5cm, font={\small\bfseries\cjkfont},
        rounded corners=5pt, text width=2cm, align=center] (act3) at (6,0) {Act III\\以色列};

  \node[rectangle, draw=JesusRed, fill=JesusRed!25,
        minimum width=2.2cm, minimum height=1.5cm, font={\small\bfseries\cjkfont},
        rounded corners=5pt, text width=2cm, align=center] (act4) at (9,0) {Act IV\\基督};

  \node[rectangle, draw=OrdinaryGreen!80!black, fill=OrdinaryGreen!20,
        minimum width=2.2cm, minimum height=1.5cm, font={\small\bfseries\cjkfont},
        rounded corners=5pt, text width=2cm, align=center] (act5) at (12,0) {Act V\\教會};

  % Arrows
  \draw[->, line width=1.5pt, LiturgicalGold] (act1) -- (act2);
  \draw[->, line width=1.5pt, JesusRed] (act2) -- (act3);
  \draw[->, line width=1.5pt, LiturgicalBlue] (act3) -- (act4);
  \draw[->, line width=1.5pt, JesusRed] (act4) -- (act5);

  % Scripture references below
  \node[font={\tiny\cjkfont}, color=TextGray] at (0,-1.2) {\cjkfont\upshape\selectfont 創1-2};
  \node[font={\tiny\cjkfont}, color=TextGray] at (3,-1.2) {\cjkfont\upshape\selectfont 創3-11};
  \node[font={\tiny\cjkfont}, color=TextGray] at (6,-1.2) {\cjkfont\upshape\selectfont 創12-瑪};
  \node[font={\tiny\cjkfont}, color=TextGray] at (9,-1.2) {\cjkfont\upshape\selectfont 四福音};
  \node[font={\tiny\cjkfont}, color=TextGray] at (12,-1.2) {\cjkfont\upshape\selectfont 徒-啟};

  % Future/Consummation arrow
  \draw[->, line width=1.5pt, LiturgicalGold, dashed] (act5.east) -- ++(1.5,0)
    node[right, font={\small\bfseries\cjkfont}, color=LiturgicalGold] {永恆 Eternity};

  % Title
  \node[font={\normalsize\bfseries\cjkfont}, color=LiturgicalRed] at (6,2) {\cjkfont\upshape\selectfont THE BIBLICAL DRAMA 聖經五幕劇};

\end{tikzpicture}
}

