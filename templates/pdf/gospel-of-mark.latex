%% ============================================
%% APPENDIX D: ABOUT RED LETTER BIBLE
%% ============================================
\chapter*{附錄四：紅字聖經說明 (Appendix D: About the Red Letter Format)}
\addcontentsline{toc}{chapter}{附錄四：紅字聖經說明 (Appendix D: About the Red Letter Format)}
\markboth{}{}

\section*{什麼是紅字聖經？}

紅字聖經是一種聖經印刷傳統，將耶穌基督親口所說的話用\textcolor{JesusRed}{紅色}印刷，以區別於敘事文字與他人話語。這種格式起源於1899年，由 Louis Klopsch 首先用於英文聖經。

\section*{本書的紅字標記}

\begin{itemize}
\item \textcolor{JesusRed}{\textit{耶穌直接說的話}} —— 紅色標示
\item 敘事文字、他人話語（包括污靈、法利賽人、門徒的話）—— 黑色正體
\item 天父從天上發出的聲音（1:11；9:7）—— 不作紅字處理，因非耶穌本人的話
\item 舊約引文 —— 保留原樣，不作紅字處理
\end{itemize}

\section*{馬可福音紅字的特殊之處}

與約翰福音「樓上私語」五章幾乎整段是紅字不同，馬可福音的敘事風格「省略言語、聚焦行動」——序言（1:1-13）三段中，耶穌完全沒有一句直接引語，直到1:14「日期滿了」才第一次開口。這個安排恰恰印證馬可的筆法：僕人的身分先於僕人的話語，行動比言語更早、更多地見證了祂是誰。

\vspace{0.5cm}
\begin{center}
\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{4.2in}
\centering\vspace{0.2cm}
\textcolor{JesusRed}{\textit{「因為人子來，並不是要受人的服事，乃是要服事人，\\
並且要捨命，作多人的贖價。」}}\\[0.3em]
\small — 馬可福音 10:45
\vspace{0.2cm}
\end{minipage}}
\end{center}

\pagebreak

%% ============================================
%% APPENDIX E: FOUR GOSPELS DISTINCTIVES
%% ============================================
\chapter*{附錄五：馬可福音在四福音中的獨特性 (Appendix E: Mark Among the Four Gospels)}
\addcontentsline{toc}{chapter}{附錄五：馬可福音在四福音中的獨特性 (Appendix E: Mark Among the Four Gospels)}
\markboth{}{}

\section*{四福音四活物——四個角度寫同一位耶穌}

{\small
\begin{tabular}{@{}p{2.0cm}p{1.6cm}p{3.4cm}p{2.0cm}p{2.5cm}@{}}
\toprule
\textbf{福音書} & \textbf{活物} & \textbf{身份} & \textbf{開卷起點} & \textbf{家譜} \\
\midrule
馬太 & 獅子 & 王（大衛的子孫） & 亞伯拉罕 & 有（往下數到耶穌） \\
\textbf{馬可} & \textbf{牛} & \textbf{僕人} & \textbf{施洗約翰出來} & \textbf{無（僕人不需家譜）} \\
路加 & 人 & 完全人（末後的亞當） & 亞當 & 有（往上追到神） \\
約翰 & 鷹 & 神（永恆的道） & 太初 & 無（神沒有家譜） \\
\bottomrule
\end{tabular}
}

\vspace{0.4cm}
\section*{馬可福音的獨有特徵}

\begin{itemize}
\item 全書無家譜、無降生敘事——開卷第一句直接宣告「神的兒子」（1:1）
\item 現存最古老的抄本止於16:8，以婦女的懼怕與沉默戛然而止——經文鑑別學上著名的懸案
\item 「立刻」(\textit{euthys}) 出現約40次，是全書招牌的敘事節奏詞，但正如附錄四所述，這是文體而非鑰匙
\item 唯一記載耶穌「與野獸同在一處」（1:13）與伯賽大瞎子分兩階段醫治（8:22-26）的福音書
\item 一個比喻也沒有獨創——四個天國比喻（4章）均見於馬太或路加的平行記載，但馬可的敘述通常最簡潔
\item 早期教父帕皮亞（Papias, 約主後140年）記載：馬可是彼得的「傳譯者」，忠實記錄彼得所傳講的內容
\end{itemize}

\section*{寫作對象與筆法}

\begin{itemize}
\item 針對羅馬外邦讀者而寫——翻譯亞蘭文詞語給讀者（5:41；7:34；15:34：Talitha cumi, Ephphatha, Eloi Eloi lema sabachthani）
\item 較少引用舊約經文，卻仍在開卷就引用以賽亞書——立刻交代耶穌事工的神聖起源，而非向猶太讀者論證
\item 一般認為成書於主後50-70年間，可能是四福音書中最早寫成的一卷
\end{itemize}

\noindent 對觀福音（太、可、路）共享大量平行材料，但馬可的敘述通常最簡短、最少解釋——這正符合「僕人」的記號：僕人不需要冗長的自我介紹，只需要立刻開始服事。

\pagebreak

%% ============================================
%% APPENDIX F: THE MESSIANIC SECRET AND SERVANT SIGNS
%% ============================================
\chapter*{附錄六：馬可福音的彌賽亞秘密與僕人記號 (Appendix F: The Messianic Secret and Servant Signs)}
\addcontentsline{toc}{chapter}{附錄六：馬可福音的彌賽亞秘密與僕人記號 (Appendix F: The Messianic Secret and Servant Signs)}
\markboth{}{}

\noindent\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{6.0in}\vspace{0.18cm}
\centering
{\footnotesize\bfseries\color{ChapterRed} 讀經之鑰 \;\textperiodcentered\; The Key}\\[0.4em]
{\footnotesize\color{TextGray}
馬可福音沒有像約翰福音那樣的「兆頭」清單，卻有一條同樣清楚的線索——
耶穌反覆吩咐人「不要告訴人」祂的身分，直到十字架下，才由一個外邦百夫長第一次公開宣告。}
\vspace{0.18cm}
\end{minipage}}

\vspace{0.3cm}

\noindent\textbf{總綱經文}（可10:45）：

\begin{center}
\fcolorbox{ScriptureGold}{ScriptureBg}{%
\begin{minipage}{5.5in}
\centering\vspace{0.15cm}
{\footnotesize\color{TextGray}
「因為人子來，並不是要受人的服事，乃是要服事人，並且要捨命，作多人的贖價。」\\[0.15em]
\scriptsize — 馬可福音 10:45}
\vspace{0.15cm}
\end{minipage}}
\end{center}

\vspace{0.3cm}

\section*{彌賽亞秘密：六次「不要告訴人」}

{\small
\begin{tabular}{@{}p{1.6cm}p{3.2cm}p{7.9cm}@{}}
\toprule
\textbf{經文} & \textbf{對象} & \textbf{吩咐} \\
\midrule
1:34 & 眾污靈 & 不許牠們說話，因為牠們認識他 \\
1:44 & 痲瘋病人 & 不要告訴人，只要去給祭司察看 \\
3:12 & 眾污靈 & 再三囑咐不要把他顯露出來 \\
5:43 & 睚魯家人 & 切切囑咐不要讓人知道這事 \\
7:36 & 被醫治的聾啞人 & 越囑咐不要告訴人，眾人卻越發傳揚 \\
8:30；9:9 & 門徒 & 不可對任何人說起他是基督；下山前不要告訴人所見的 \\
\bottomrule
\end{tabular}
}

\vspace{0.3cm}
\section*{「這到底是誰」：貫穿全書的提問}

\begin{itemize}
\item 1:27——會堂裏的人：「這是甚麼事？是個新的教導啊！」
\item 4:41——平靜風浪後，門徒：「這到底是誰？連風和海都聽從他。」
\item 6:3——拿撒勒鄉人：「這不是那木匠嗎？」
\item 8:27-29——耶穌親自發問：「你們說我是誰？」彼得回答：「你是基督。」
\item 15:39——十字架下，百夫長：「這人真是神的兒子！」（全書第一次由人在耶穌在世時公開如此宣告）
\end{itemize}

\vspace{0.3cm}
\section*{三次預言受難：走向十字架的框架}

{\small
\begin{tabular}{@{}p{1.2cm}p{2.2cm}p{4.0cm}p{5.3cm}@{}}
\toprule
\textbf{\#} & \textbf{經文} & \textbf{門徒的誤解} & \textbf{耶穌的教導} \\
\midrule
1 & 8:31 & 彼得責備耶穌 & 捨己、背十字架跟從我（8:34-38） \\
2 & 9:31 & 門徒爭論誰最大 & 為首的要作眾人的用人（9:35） \\
3 & 10:33-34 & 雅各、約翰求座位 & 人子來是要服事人、捨命作贖價（10:45） \\
\bottomrule
\end{tabular}
}

\vspace{0.3cm}
\noindent\textbf{帶領提問：}彌賽亞秘密為何在十字架下才被打破？耶穌的身分，是不是必須透過捨命服事才能被真正認出？

\pagebreak

