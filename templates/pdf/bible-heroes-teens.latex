% ============================================================================
% Bible Heroes for Teens - Liturgical Style Edition
% 圣经英雄传 — 青少年版 (12岁以上)
% Large Print (8.5×11" Letter) with Red Letter Bible
% Bilingual Chinese-English
% Based on Gospel Harmony Liturgical Template
% Requires XeLaTeX for CJK support
% ============================================================================

\documentclass[12pt,twoside,openright]{memoir}

%% ============================================
%% PAGE SIZE - 8.5×11" Letter
%% ============================================
\setstocksize{11in}{8.5in}
\settrimmedsize{\stockheight}{\stockwidth}{*}
\settrims{0pt}{0pt}

% Generous margins for readability
\setlrmarginsandblock{1.25in}{1in}{*}
\setulmarginsandblock{1in}{1.25in}{*}
\setheadfoot{0.5in}{0.5in}
\setheaderspaces{*}{0.3in}{*}
\checkandfixthelayout

%% ============================================
%% FONT SETUP WITH CJK LINE BREAKING
%% ============================================
\usepackage{fontspec}

% Main CJK fonts - large and readable
\setmainfont{Songti SC}[
  BoldFont=Songti SC Bold,
  ItalicFont=Kaiti SC
]
\setsansfont{PingFang SC}
\setmonofont{Menlo}

%% Enable CJK line breaking - critical for Chinese text
\XeTeXlinebreaklocale "zh"
\XeTeXlinebreakskip = 0pt plus 1pt minus 0.1pt

%% ============================================
%% LINE SPACING - Large Print for Readability
%% ============================================
\linespread{1.35}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.5em}

%% ============================================
%% COLOR SCHEME - Liturgical Edition
%% ============================================
\usepackage{xcolor}

% Primary liturgical colors
\definecolor{LiturgicalRed}{RGB}{165,30,30}       % Deep ceremonial red
\definecolor{LiturgicalGold}{RGB}{184,134,11}     % Gold for ornaments
\definecolor{LiturgicalBlue}{RGB}{40,60,100}      % Deep blue for headings
\definecolor{RubricRed}{RGB}{180,40,40}           % Instructions in red

% RED LETTER BIBLE - Jesus's Words
\definecolor{JesusRed}{RGB}{180,0,0}              % Deep red letter Bible red

% Liturgical season colors
\definecolor{AdventBlue}{RGB}{75,0,130}           % Violet/Purple for Advent
\definecolor{OrdinaryGreen}{RGB}{0,128,0}         % Green for Ordinary Time
\definecolor{HolyWeekRed}{RGB}{139,0,0}           % Deep red for Passion
\definecolor{EasterGold}{RGB}{255,215,0}          % Gold for Easter

% Box colors
\definecolor{ScriptureBg}{RGB}{252,250,245}       % Cream background
\definecolor{ThinkBg}{RGB}{245,248,252}           % Light blue for reflection
\definecolor{NoteBg}{RGB}{255,253,245}            % Note background

% Text colors
\definecolor{TextGray}{RGB}{50,50,50}
\definecolor{LightGray}{RGB}{120,120,120}

% Hero colors for different parts
\definecolor{OTHeroColor}{RGB}{139,90,43}         % Bronze for OT heroes
\definecolor{JesusColor}{RGB}{165,30,30}          % Red for Jesus section
\definecolor{NTHeroColor}{RGB}{70,130,180}        % Steel blue for NT heroes

%% ============================================
%% GRAPHICS AND TIKZ
%% ============================================
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{
  shapes,
  shapes.geometric,
  arrows,
  arrows.meta,
  positioning,
  calc,
  decorations.pathmorphing,
  patterns,
  shadows
}

%% ============================================
%% RED LETTER BIBLE COMMAND
%% ============================================
\newcommand{\jesus}[1]{\textcolor{JesusRed}{\textit{#1}}}

%% ============================================
%% SCRIPTURE VERSE COMMAND
%% ============================================
\newcommand{\bibleverse}[1]{%
  \vspace{0.5em}
  \begin{center}
  \fcolorbox{LiturgicalGold}{ScriptureBg}{%
    \begin{minipage}{0.85\textwidth}
      \centering
      \vspace{0.3em}
      \itshape\color{TextGray} #1
      \vspace{0.3em}
    \end{minipage}
  }
  \end{center}
  \vspace{0.5em}
}

%% ============================================
%% REFLECTION BOX COMMAND
%% ============================================
\newcommand{\thinkbox}[1]{%
  \vspace{0.5em}
  \begin{center}
  \fcolorbox{LiturgicalBlue}{ThinkBg}{%
    \begin{minipage}{0.85\textwidth}
      \vspace{0.3em}
      {\small\bfseries\color{LiturgicalBlue} 思考题 Think About It:}\\[0.3em]
      \small\color{TextGray} #1
      \vspace{0.3em}
    \end{minipage}
  }
  \end{center}
  \vspace{0.5em}
}

%% ============================================
%% LITURGICAL COMMANDS
%% ============================================

% Section divider with cross
\newcommand{\liturgicaldiv}{%
  \begin{center}
    \vspace{0.5em}
    {\Large\color{LiturgicalGold}\ensuremath{\dagger}\quad\ensuremath{\dagger}\quad\ensuremath{\dagger}}
    \vspace{0.5em}
  \end{center}
}

% Ornamental divider
\newcommand{\ornamentdiv}{%
  \begin{center}
    \vspace{0.3em}
    \begin{tikzpicture}
      \draw[LiturgicalGold, line width=1pt] (-2,0) -- (-0.5,0);
      \node[color=LiturgicalGold] at (0,0) {\ensuremath{\diamond}};
      \draw[LiturgicalGold, line width=1pt] (0.5,0) -- (2,0);
    \end{tikzpicture}
    \vspace{0.3em}
  \end{center}
}

% Drop cap
\newcommand{\dropcap}[1]{%
  {\color{LiturgicalRed}\fontsize{42}{48}\selectfont\bfseries #1}%
}

%% ============================================
%% HERO SCENE DIAGRAMS (TikZ)
%% ============================================

% Abraham and the Stars (God's Promise)
\newcommand{\abrahamscene}{%
\begin{tikzpicture}[scale=0.8]
  % Night sky
  \fill[blue!80!black] (0,2) rectangle (5,5);
  % Stars (many, representing God's promise)
  \foreach \x/\y in {0.3/4.5,0.8/3.8,1.2/4.2,1.7/3.5,2.2/4.8,2.8/4,3.3/4.5,3.8/3.7,4.2/4.3,4.7/4,
                     0.5/3,1.5/2.8,2.5/3.2,3.5/2.5,4.5/3.3,1/4.7,2/3.9,3/4.6,4/4.1} {
    \fill[yellow!90] (\x,\y) circle (0.06);
  }
  % Larger stars
  \foreach \x/\y in {1.5/4.5,3/3.5,4/4.5} {
    \fill[yellow!90] (\x,\y) circle (0.1);
    \foreach \a in {0,72,144,216,288} {
      \draw[yellow!90, line width=0.5pt] (\x,\y) -- ++(\a:0.15);
    }
  }
  % Desert ground
  \fill[yellow!40!brown!30] (0,0) rectangle (5,2);
  % Abraham figure looking up
  \fill[brown!60] (2.5,1.8) circle (0.25); % head
  \fill[brown!50] (2.3,0.8) rectangle (2.7,1.6); % body
  \fill[white!80] (2.2,1.6) -- (2.5,1.9) -- (2.8,1.6) -- cycle; % beard
  % Arm raised to sky
  \draw[brown!50, line width=3pt] (2.7,1.4) -- (3.2,2.2);
  % Tent in background
  \fill[brown!40] (0.5,0.5) -- (1.5,1.5) -- (2.5,0.5) -- cycle;
  % Moon
  \fill[yellow!30] (4.5,4.5) circle (0.25);
  \fill[blue!80!black] (4.35,4.5) circle (0.2);
\end{tikzpicture}%
}

% Jacob Wrestling with God
\newcommand{\jacobscene}{%
\begin{tikzpicture}[scale=0.8]
  % Night sky with dawn breaking
  \fill[blue!60!black] (0,3) rectangle (5,5);
  \fill[orange!30] (0,3) rectangle (5,3.5);
  % River (Jabbok)
  \fill[blue!40] (0,0) rectangle (5,1);
  % Riverbank
  \fill[brown!30] (0,1) rectangle (5,3);
  % Jacob wrestling (two figures intertwined)
  % Angel figure (glowing)
  \fill[white!80] (2.8,2.5) circle (0.3); % head
  \fill[white!70] (2.6,1.5) rectangle (3,2.3); % body
  \fill[yellow!30] (2.8,2.5) circle (0.5); % glow
  % Jacob figure
  \fill[brown!60] (2.2,2.3) circle (0.25); % head
  \fill[brown!50] (2,1.3) rectangle (2.4,2.1); % body
  % Arms locked in wrestling
  \draw[brown!50, line width=3pt] (2.4,1.8) -- (2.6,1.8);
  \draw[white!70, line width=3pt] (2.6,1.9) -- (2.4,1.9);
  % Stars
  \foreach \x/\y in {0.5/4,1.5/4.5,3.5/4.2,4.5/4.7} {
    \fill[yellow!80] (\x,\y) circle (0.05);
  }
  % Rising sun hint
  \fill[orange!60] (5,3.2) circle (0.3);
\end{tikzpicture}%
}

% Joshua and Jericho Walls
\newcommand{\joshuascene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!25] (0,3) rectangle (5,5);
  % Ground
  \fill[yellow!30] (0,0) rectangle (5,3);
  % Jericho walls (crumbling)
  \fill[brown!50] (3,1) rectangle (3.5,4);
  \fill[brown!50] (3.5,1) rectangle (4,3.5);
  \fill[brown!50] (4,1) rectangle (4.5,3);
  % Falling blocks
  \fill[brown!60] (3.8,2.5) rectangle (4.1,2.8);
  \fill[brown!60] (4.2,2) rectangle (4.5,2.3);
  \fill[brown!60] (3.6,1.5) rectangle (3.9,1.8);
  % Cracks
  \draw[black, line width=1pt] (3.2,2) -- (3.4,2.5) -- (3.3,3);
  \draw[black, line width=1pt] (3.7,2.5) -- (3.9,3) -- (3.8,3.5);
  % Joshua figure with sword raised
  \fill[brown!60] (1.5,2.3) circle (0.25); % head
  \fill[brown!50] (1.3,1.3) rectangle (1.7,2.1); % body
  \draw[gray!70, line width=2pt] (1.7,2) -- (2.3,2.8); % sword
  % Priests with trumpets (ark bearers)
  \foreach \x in {0.5,0.9} {
    \fill[white!80] (\x,2) circle (0.15);
    \fill[white!70] (\x-0.08,1.3) rectangle (\x+0.08,1.85);
    \draw[yellow!70, line width=1.5pt] (\x+0.1,1.7) -- (\x+0.4,1.9); % trumpet
  }
  % Ark of covenant
  \fill[yellow!70] (2,1.5) rectangle (2.6,1.8);
  \fill[yellow!80] (2.1,1.8) rectangle (2.5,2);
  % Sun
  \fill[yellow!80] (0.8,4.3) circle (0.3);
\end{tikzpicture}%
}

% Esther Before the King
\newcommand{\estherscene}{%
\begin{tikzpicture}[scale=0.8]
  % Palace interior
  \fill[purple!20] (0,0) rectangle (5,5);
  % Throne platform
  \fill[purple!40] (0,0) rectangle (5,0.8);
  % Columns
  \fill[yellow!70] (0.3,0.8) rectangle (0.6,4.5);
  \fill[yellow!70] (4.4,0.8) rectangle (4.7,4.5);
  % Throne
  \fill[purple!60] (3.5,1) rectangle (4.3,2.8);
  \fill[yellow!80] (3.6,2.8) rectangle (4.2,3.2); % top
  % King on throne
  \fill[brown!50] (3.9,2.3) circle (0.2); % head
  \fill[purple!70] (3.7,1.5) rectangle (4.1,2.1); % body
  \fill[yellow!90] (3.75,2.4) -- (3.9,2.65) -- (4.05,2.4) -- cycle; % crown
  % Scepter extended
  \draw[yellow!90, line width=3pt] (3.7,1.8) -- (2.5,2.2);
  % Esther approaching
  \fill[brown!50] (1.5,2) circle (0.22); % head
  \fill[blue!50] (1.3,1) -- (1.5,1.8) -- (1.7,1) -- (1.9,0.8) -- (1.1,0.8) -- cycle; % dress
  % Crown on Esther
  \fill[yellow!80] (1.4,2.15) -- (1.5,2.35) -- (1.6,2.15) -- cycle;
  % Esther's outstretched hand toward scepter
  \draw[brown!50, line width=2pt] (1.7,1.6) -- (2.3,2);
  % Royal tapestry in background
  \fill[red!40] (1.8,3.5) rectangle (3.2,4.5);
  \draw[yellow!70, line width=1pt] (1.8,3.5) rectangle (3.2,4.5);
  % Star symbol (Esther means "star")
  \fill[yellow!90] (2.5,4) circle (0.15);
  \foreach \a in {0,72,144,216,288} {
    \draw[yellow!90, line width=1pt] (2.5,4) -- ++(\a:0.25);
  }
\end{tikzpicture}%
}

% Joseph's Coat of Many Colors
\newcommand{\josephscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!20] (0,3) rectangle (5,5);
  % Ground
  \fill[yellow!30] (0,0) rectangle (5,3);
  % Joseph figure with colorful coat
  \fill[brown!60] (2.5,2) circle (0.3); % head
  \fill[red!70] (2.2,0.5) -- (2.5,1.7) -- (2.8,0.5) -- cycle; % coat base
  \fill[blue!60] (2.0,1.2) -- (2.3,1.5) -- (2.0,0.8) -- cycle; % left sleeve
  \fill[green!60] (3.0,1.2) -- (2.7,1.5) -- (3.0,0.8) -- cycle; % right sleeve
  \fill[yellow!70] (2.3,1.3) rectangle (2.7,0.8); % middle stripe
  \fill[purple!60] (2.35,0.8) rectangle (2.65,0.5); % bottom stripe
  % Sun
  \fill[yellow!80] (4.2,4.2) circle (0.4);
  \foreach \a in {0,45,...,315} {
    \draw[yellow!80, line width=2pt] (4.2,4.2) -- ++(\a:0.6);
  }
  % Brothers in background
  \foreach \x in {0.5,1,1.5,3.5,4,4.5} {
    \fill[brown!40] (\x,2.2) circle (0.15);
    \fill[brown!30] (\x-0.1,1.5) rectangle (\x+0.1,2.0);
  }
\end{tikzpicture}%
}

% Moses and the Red Sea
\newcommand{\mosesscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!30] (0,3) rectangle (5,5);
  % Water walls
  \fill[blue!60] (0,0) rectangle (1.5,4);
  \fill[blue!60] (3.5,0) rectangle (5,4);
  % Dry path
  \fill[yellow!40] (1.5,0) rectangle (3.5,4);
  % Moses figure
  \fill[brown!60] (2.5,3.5) circle (0.25); % head
  \fill[brown!40] (2.3,2.2) rectangle (2.7,3.3); % body
  % Staff raised
  \draw[brown!70, line width=3pt] (2.7,2.5) -- (3.2,4.2);
  % People following
  \foreach \y in {1,1.5,2} {
    \fill[brown!40] (2.5,\y) circle (0.12);
  }
  % Fish in water
  \fill[gray!50] (0.7,2) ellipse (0.2 and 0.1);
  \fill[gray!50] (4.3,2.5) ellipse (0.2 and 0.1);
  % Cloud above
  \fill[white] (2.5,4.6) ellipse (0.8 and 0.3);
\end{tikzpicture}%
}

% Samson and the Pillars
\newcommand{\samsonscene}{%
\begin{tikzpicture}[scale=0.8]
  % Background
  \fill[gray!20] (0,0) rectangle (5,5);
  % Pillars
  \fill[gray!60] (1,0) rectangle (1.5,4.5);
  \fill[gray!60] (3.5,0) rectangle (4,4.5);
  % Roof blocks
  \fill[gray!50] (0,4.3) rectangle (2,5);
  \fill[gray!50] (3,4.3) rectangle (5,5);
  % Samson figure (muscular, pushing)
  \fill[brown!60] (2.5,2.8) circle (0.35); % head
  \fill[brown!50] (2.1,1.2) rectangle (2.9,2.5); % body
  % Long hair
  \draw[black, line width=1.5pt] (2.2,3) .. controls (1.8,3.2) .. (1.5,2.8);
  \draw[black, line width=1.5pt] (2.8,3) .. controls (3.2,3.2) .. (3.5,2.8);
  % Arms pushing pillars
  \draw[brown!50, line width=4pt] (2.1,2.2) -- (1.5,2.2);
  \draw[brown!50, line width=4pt] (2.9,2.2) -- (3.5,2.2);
  % Cracks in pillars
  \draw[black, line width=1pt] (1.2,3) -- (1.3,3.5) -- (1.2,4);
  \draw[black, line width=1pt] (3.7,3) -- (3.8,3.5) -- (3.7,4);
\end{tikzpicture}%
}

% Ruth Gleaning in the Field
\newcommand{\ruthscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!20] (0,3.5) rectangle (5,5);
  % Field
  \fill[yellow!50] (0,0) rectangle (5,3.5);
  % Wheat stalks
  \foreach \x in {0.3,0.8,1.3,1.8,2.3,2.8,3.3,3.8,4.3,4.7} {
    \draw[yellow!70!brown, line width=1.5pt] (\x,0) -- (\x,2.5);
    \fill[yellow!80] (\x,2.5) ellipse (0.1 and 0.2);
  }
  % Ruth figure (bending to glean)
  \fill[brown!50] (2.5,2.2) circle (0.25); % head
  \fill[blue!40] (2.2,1.2) -- (2.5,2) -- (2.8,1.2) -- (3,0.8) -- (2,0.8) -- cycle; % dress
  % Head covering
  \fill[white!90] (2.3,2.3) .. controls (2.5,2.6) .. (2.7,2.3) -- cycle;
  % Gathered wheat in hand
  \fill[yellow!80] (3.2,1.5) ellipse (0.15 and 0.3);
  % Sun
  \fill[yellow!80] (4.2,4.3) circle (0.35);
\end{tikzpicture}%
}

% David vs Goliath
\newcommand{\davidscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!25] (0,3) rectangle (5,5);
  % Ground
  \fill[green!30] (0,0) rectangle (5,3);
  % Goliath (big, falling)
  \fill[gray!50] (3.8,3.2) circle (0.4); % head
  \fill[gray!60] (3.5,1.5) rectangle (4.1,3); % body
  \fill[gray!70] (3.8,3.6) -- (3.5,3.8) -- (4.1,3.8) -- cycle; % helmet
  % Falling motion
  \draw[red!60, line width=2pt] (3.8,3.2) circle (0.15); % hit mark on forehead
  % David (small, victorious)
  \fill[brown!50] (1.2,2.3) circle (0.2); % head
  \fill[brown!40] (1,1.5) rectangle (1.4,2.1); % body
  % Sling
  \draw[brown!60, line width=1.5pt] (1.4,2) .. controls (1.8,2.5) .. (1.5,2.8);
  % Stone trajectory
  \draw[gray!60, dashed, line width=1pt] (1.5,2.8) -- (3.8,3.2);
  \fill[gray!70] (2.5,3) circle (0.08); % stone
  % Staff with sheep in background
  \fill[white] (0.5,1.2) circle (0.15);
  \fill[white] (0.8,1) circle (0.15);
\end{tikzpicture}%
}

% Elijah and Fire from Heaven
\newcommand{\elijahscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky (dark, dramatic)
  \fill[blue!40] (0,3) rectangle (5,5);
  % Ground
  \fill[brown!30] (0,0) rectangle (5,3);
  % Altar
  \fill[gray!60] (2,0.5) rectangle (3,1.5);
  \fill[gray!50] (1.8,1.5) rectangle (3.2,1.7);
  % Wood on altar
  \fill[brown!50] (2.1,1.7) rectangle (2.9,2);
  % Fire from heaven
  \fill[red!70] (2.5,2) -- (2,3.5) -- (2.5,3) -- (3,3.5) -- cycle;
  \fill[yellow!80] (2.5,2.2) -- (2.2,3) -- (2.5,2.7) -- (2.8,3) -- cycle;
  \fill[orange!80] (2.5,2) -- (2.3,2.8) -- (2.5,2.5) -- (2.7,2.8) -- cycle;
  % Lightning from sky
  \draw[yellow!90, line width=2pt] (2.5,5) -- (2.3,4) -- (2.7,3.5) -- (2.5,3);
  % Elijah figure (kneeling, praying)
  \fill[brown!50] (4,2) circle (0.2); % head
  \fill[brown!40] (3.8,1.2) rectangle (4.2,1.8); % body
  % Arms raised
  \draw[brown!40, line width=3pt] (4,1.8) -- (4.3,2.5);
  \draw[brown!40, line width=3pt] (4,1.8) -- (3.7,2.5);
  % Water trenches
  \fill[blue!50] (1.5,0.3) rectangle (3.5,0.5);
\end{tikzpicture}%
}

% Peter Walking on Water
\newcommand{\peterscene}{%
\begin{tikzpicture}[scale=0.8]
  % Night sky
  \fill[blue!60] (0,3) rectangle (5,5);
  % Stars
  \foreach \x/\y in {0.5/4,1.2/4.5,2/4.2,3.5/4.7,4.3/4.1} {
    \fill[white] (\x,\y) circle (0.05);
  }
  % Stormy water
  \fill[blue!40] (0,0) rectangle (5,3);
  \draw[blue!60, line width=1pt] (0,2.8) sin (1,3) cos (2,2.8) sin (3,3) cos (4,2.8) sin (5,3);
  \draw[blue!50, line width=1pt] (0,2.3) sin (1,2.5) cos (2,2.3) sin (3,2.5) cos (4,2.3) sin (5,2.5);
  % Jesus figure (glowing)
  \fill[white!80] (1.5,2.2) circle (0.5); % glow
  \fill[white!90] (1.5,2.5) circle (0.2); % head
  \fill[white!80] (1.3,1.5) rectangle (1.7,2.3); % robe
  % Peter walking toward Jesus
  \fill[brown!50] (3.5,2.3) circle (0.2); % head
  \fill[brown!40] (3.3,1.4) rectangle (3.7,2.1); % body
  % Peter's arms reaching out
  \draw[brown!40, line width=2pt] (3.3,2) -- (2.5,2.3);
  % Boat in background
  \fill[brown!60] (4.5,1.5) -- (4,1.8) -- (4,1.3) -- (5,1.3) -- (5,1.8) -- cycle;
\end{tikzpicture}%
}

% Paul on the Damascus Road
\newcommand{\paulscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky with bright light
  \fill[blue!20] (0,3) rectangle (5,5);
  % Blinding light from above
  \fill[yellow!40] (2.5,5) -- (1,3) -- (4,3) -- cycle;
  \fill[white!80] (2.5,4.5) circle (0.5);
  % Light rays
  \foreach \a in {-60,-30,0,30,60} {
    \draw[yellow!80, line width=2pt] (2.5,4.5) -- ++(\a:-2);
  }
  % Road
  \fill[brown!40] (0,0) -- (0,2) -- (5,1) -- (5,0) -- cycle;
  % Saul fallen from horse
  \fill[brown!50] (2.8,1.5) circle (0.2); % head
  \fill[gray!40] (2.5,0.8) -- (2.8,1.3) -- (3.3,1) -- (3,0.5) -- cycle; % fallen body
  % Horse
  \fill[brown!60] (4,2) ellipse (0.4 and 0.25); % body
  \fill[brown!60] (4.3,2.3) circle (0.15); % head
  \draw[brown!60, line width=2pt] (3.7,1.8) -- (3.7,1.3); % legs
  \draw[brown!60, line width=2pt] (4.2,1.8) -- (4.2,1.3);
  % Companions standing confused
  \fill[brown!40] (0.8,2) circle (0.15);
  \fill[brown!30] (0.7,1.3) rectangle (0.9,1.8);
  \fill[brown!40] (1.3,2.1) circle (0.15);
  \fill[brown!30] (1.2,1.4) rectangle (1.4,1.9);
\end{tikzpicture}%
}

% Jesus Teaching (Sermon on Mount)
\newcommand{\jesusscene}{%
\begin{tikzpicture}[scale=0.8]
  % Sky
  \fill[blue!20] (0,3.5) rectangle (5,5);
  % Mountain/hill
  \fill[green!40] (0,0) -- (0,2) -- (2.5,3.5) -- (5,2) -- (5,0) -- cycle;
  % Jesus on the mount
  \fill[white!90] (2.5,3.2) circle (0.3); % head with halo
  \fill[white!80] (2.5,3.2) circle (0.25); % head
  \fill[white!70] (2.2,2) rectangle (2.8,3); % robe
  % Halo
  \draw[yellow!80, line width=2pt] (2.5,3.2) circle (0.35);
  % Crowd listening
  \foreach \x/\y in {0.5/1,1/1.2,1.5/1.5,2/1.3,3/1.3,3.5/1.5,4/1.2,4.5/1} {
    \fill[brown!40] (\x,\y) circle (0.12);
  }
  % Arms extended in teaching
  \draw[white!70, line width=3pt] (2.2,2.7) -- (1.7,2.9);
  \draw[white!70, line width=3pt] (2.8,2.7) -- (3.3,2.9);
\end{tikzpicture}%
}

% Cross Scene
\newcommand{\crossscene}{%
\begin{tikzpicture}[scale=0.8]
  % Dark sky
  \fill[gray!40] (0,2.5) rectangle (5,5);
  % Ground (Golgotha)
  \fill[brown!40] (0,0) -- (0,2.5) -- (1,2) -- (2.5,2.8) -- (4,2) -- (5,2.5) -- (5,0) -- cycle;
  % Three crosses
  % Main cross (center, larger)
  \fill[brown!70] (2.3,1.5) rectangle (2.7,4.5);
  \fill[brown!70] (1.5,3.5) rectangle (3.5,3.8);
  % Left cross
  \fill[brown!60] (0.9,1.8) rectangle (1.1,3.8);
  \fill[brown!60] (0.5,3) rectangle (1.5,3.2);
  % Right cross
  \fill[brown!60] (3.9,1.8) rectangle (4.1,3.8);
  \fill[brown!60] (3.5,3) rectangle (4.5,3.2);
  % Sun/moon (eclipse)
  \fill[gray!60] (4,4.3) circle (0.3);
  \fill[black!40] (4.1,4.3) circle (0.25);
  % INRI sign
  \fill[white] (2.1,4) rectangle (2.9,4.3);
  \node[font=\tiny] at (2.5,4.15) {INRI};
\end{tikzpicture}%
}

% Resurrection Scene
\newcommand{\resurrectionscene}{%
\begin{tikzpicture}[scale=0.8]
  % Dawn sky
  \fill[orange!30] (0,3) rectangle (5,5);
  \fill[yellow!40] (0,4) rectangle (5,5);
  % Garden
  \fill[green!30] (0,0) rectangle (5,3);
  % Empty tomb
  \fill[gray!50] (1,1) -- (1,2.5) arc (180:0:0.8) -- (2.6,1) -- cycle;
  \fill[black!30] (1.3,1) arc (180:0:0.5) -- (2.3,1) -- cycle; % opening
  % Stone rolled away
  \fill[gray!60] (3,1.2) circle (0.4);
  % Risen Jesus (glowing figure)
  \fill[yellow!30] (4,2.5) circle (0.8); % glow
  \fill[white!95] (4,2.8) circle (0.2); % head
  \fill[white!90] (3.8,1.8) rectangle (4.2,2.6); % robe
  % Grave clothes in tomb
  \fill[white!80] (1.5,1.2) rectangle (2.2,1.4);
  % Light rays
  \foreach \a in {0,30,60,90,120,150,180} {
    \draw[yellow!60, line width=1pt] (4,2.5) -- ++(\a:1.2);
  }
  % Angels
  \fill[white] (0.8,2.3) circle (0.12);
  \fill[white] (2.4,2.3) circle (0.12);
\end{tikzpicture}%
}

