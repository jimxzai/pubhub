\newcommand{\heroestimeline}{%
\begin{tikzpicture}[scale=0.85, transform shape]
  % Main timeline axis
  \draw[line width=2pt, LiturgicalGold] (-0.5,0) -- (15.5,0);

  % Era backgrounds
  \fill[OTHeroColor!20] (0,-1.8) rectangle (11.5,1.8);
  \fill[JesusColor!20] (11.5,-1.8) rectangle (13,1.8);
  \fill[NTHeroColor!20] (13,-1.8) rectangle (15.5,1.8);

  % Timeline markers with heroes (expanded)
  \foreach \x/\hero/\year in {
    0.5/{亚伯拉罕}/{2000 BC},
    1.5/{雅各}/{1900 BC},
    2.5/{约瑟}/{1850 BC},
    3.8/{摩西}/{1500 BC},
    5/{约书亚}/{1400 BC},
    6/{参孙}/{1100 BC},
    7/{路得}/{1100 BC},
    8.2/{大卫}/{1000 BC},
    9.5/{以利亚}/{870 BC},
    10.5/{以斯帖}/{480 BC},
    12.2/{耶稣}/{4 BC-30},
    14/{彼得}/{AD 30},
    15/{保罗}/{AD 35}
  } {
    \fill[LiturgicalRed] (\x,0) circle (0.1);
    \node[font=\tiny, above, text width=1cm, align=center] at (\x,0.25) {\hero};
    \node[font=\tiny, below, color=LightGray] at (\x,-0.25) {\year};
  }

  % Era labels
  \node[font=\small\bfseries, color=OTHeroColor] at (5.5,1.5) {旧约英雄 Old Testament Heroes};
  \node[font=\small\bfseries, color=JesusColor] at (12.2,1.5) {基督};
  \node[font=\small\bfseries, color=NTHeroColor] at (14.5,1.5) {使徒};

  % Title
  \node[font=\normalsize\bfseries, color=LiturgicalRed] at (7.5,-2.5) {HEROES OF FAITH 信心英雄时间轴};

\end{tikzpicture}
}

