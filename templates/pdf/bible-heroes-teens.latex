\chapter*{附录：经文索引}
\addcontentsline{toc}{chapter}{附录 Appendix}

\section*{旧约 Old Testament}

\begin{tabular}{@{}p{4cm}p{5cm}@{}}
\textbf{创世记 Genesis} & 约瑟的故事 (37-50章) \\
\textbf{出埃及记 Exodus} & 摩西的故事 (1-40章) \\
\textbf{士师记 Judges} & 参孙的故事 (13-16章) \\
\textbf{路得记 Ruth} & 路得的故事 (1-4章) \\
\textbf{撒母耳记上 1 Samuel} & 大卫与歌利亚 (17章) \\
\textbf{列王纪上 1 Kings} & 以利亚的故事 (17-19章) \\
\end{tabular}

\section*{新约 New Testament}

\begin{tabular}{@{}p{4cm}p{5cm}@{}}
\textbf{马太福音 Matthew} & 耶稣生平、登山宝训 \\
\textbf{马可福音 Mark} & 耶稣的神迹 \\
\textbf{路加福音 Luke} & 耶稣的教导 \\
\textbf{约翰福音 John} & 耶稣的身份、「我是」宣告 \\
\textbf{使徒行传 Acts} & 彼得和保罗的事工 \\
\textbf{希伯来书 Hebrews} & 信心英雄榜 (11章) \\
\end{tabular}

\vspace{1cm}

\section*{推荐阅读}

\begin{itemize}
\item \textbf{整本圣经}——这本书只是入门，整本圣经才是真正的宝藏
\item \textbf{《返璞归真》}——C.S.路易斯，基督教信仰入门经典
\item \textbf{《认识神》}——巴刻，认识神的属性
\item \textbf{《圣经导读》}——戈登·乔安妮斯，圣经整体脉络
\end{itemize}

