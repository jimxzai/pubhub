\usepackage{longtable}
\usepackage{booktabs}
\usepackage{array}
\usepackage{tabularx}
\usepackage{calc}
\usepackage{amssymb}

% Table geometry
\setlength{\LTleft}{0pt}
\setlength{\LTright}{0pt}
\setlength{\LTpre}{6pt}
\setlength{\LTpost}{6pt}
\renewcommand{\arraystretch}{1.25}

% Pandoc 3.x longtable patch
\usepackage{etoolbox}
\makeatletter
\patchcmd\longtable{\par}{\if@noskipsec\mbox{}\fi\par}{}{}
\@ifundefined{c@none}{\newcounter{none}}{}
\makeatother

% Table rules
\renewcommand{\toprule}{\hline\hline}
\renewcommand{\midrule}{\hline}
\renewcommand{\bottomrule}{\hline\hline}

%%============================================================
%% WIDOW / ORPHAN CONTROL
%%============================================================
\widowpenalty=10000
\clubpenalty=10000

%%============================================================
%% HEADERS & FOOTERS
%%============================================================
\usepackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE,RO]{\small\thepage}
\fancyhead[LO]{\small\itshape\color{LightGray}\nouppercase{\rightmark}}
\fancyhead[RE]{\small\itshape\color{LightGray}\nouppercase{\leftmark}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{%
  \hbox to\headwidth{\color{CovenantGold}\leaders\hrule height\headrulewidth\hfill}}
\fancypagestyle{plain}{%
  \fancyhf{}%
  \fancyfoot[C]{\small\thepage}%
  \renewcommand{\headrulewidth}{0pt}}

%%============================================================
%% SECTION STYLING
%%============================================================
\makeatletter

% Chapter head
\def\@makechapterhead#1{%
  \vspace*{18pt}%
  {\parindent \z@ \raggedright \normalfont
    \color{KingsNavy}\Huge\bfseries \thechapter\quad #1
    \par\nobreak
    \vskip 4pt
    {\color{CovenantGold}\hrule height 1.2pt}
    \vskip 18pt}}

\def\@makeschapterhead#1{%
  \vspace*{18pt}%
  {\parindent \z@ \raggedright \normalfont
    \color{KingsNavy}\Huge\bfseries #1
    \par\nobreak
    \vskip 4pt
    {\color{CovenantGold}\hrule height 1.2pt}
    \vskip 18pt}}

\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-2.5ex \@plus -0.5ex \@minus -.2ex}%
  {1.4ex \@plus .2ex}%
  {\normalfont\large\bfseries\color{TempleBlue}}}

\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-2ex \@plus -0.5ex \@minus -.2ex}%
  {1ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries\color{ProphetBrown}}}

\renewcommand\subsubsection{\@startsection{subsubsection}{3}{\z@}%
  {-1.5ex \@plus -0.3ex \@minus -.2ex}%
  {0.7ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries\color{TextGray}}}

\makeatother

%%============================================================
%% CUSTOM COMMANDS
%%============================================================

% Jesus's spoken words (red-letter)
\newcommand{\jesus}[1]{\textcolor{JesusRed}{#1}}

% Inline Hebrew word (auto switches font via ucharclasses; this is a
% convenience wrapper for manual override / labelling)
\newcommand{\heb}[1]{{\hebrewfont #1}}

% Inline Greek word
\newcommand{\grk}[1]{{\greekfont #1}}

% Scripture reference inline
\newcommand{\sref}[1]{\textcolor{CovenantGold}{\small(#1)}}

% Elder Wong teaching pull-quote
\newcommand{\elderwong}[1]{%
  \begin{quote}\itshape\color{ProphetBrown}
  \textbf{黃長老：}\ #1
  \end{quote}}

% Covenant emphasis
\newcommand{\covenant}[1]{\textcolor{TempleBlue}{\textbf{#1}}}

%%============================================================
%% METADATA
%%============================================================
$if(title)$\title{$title$}$endif$
$if(author)$\author{$author$}$endif$
$if(date)$\date{$date$}$else$\date{\today}$endif$

% Pandoc tight-list fix
\providecommand{\tightlist}{%
  \setlength{\itemsep}{0pt}\setlength{\parskip}{0pt}}

%%============================================================
%% DOCUMENT
%%============================================================
\begin{document}

\frontmatter

% ── Title page ──────────────────────────────────────────────
\begin{titlepage}
\thispagestyle{empty}
\vspace*{2cm}
\begin{center}
$if(title)${\Huge\bfseries\color{KingsNavy} $title$}\\[1cm]$endif$
$if(subtitle)${\Large\itshape\color{CovenantGold} $subtitle$}\\[2cm]$endif$
$if(author)${\Large $author$}\\[1cm]$endif$
\vfill
$if(publisher)${\large $publisher$}\\[0.5cm]$endif$
$if(date)${\large $date$}$else${\large \today}$endif$
\end{center}
\end{titlepage}

% ── Copyright ───────────────────────────────────────────────
\thispagestyle{empty}
\vspace*{\fill}
\begin{flushleft}\small
$if(copyright)$
$copyright$
$else$
Copyright \copyright\ \the\year\ $if(author)$$author$$endif$\\
All rights reserved.
$endif$
\end{flushleft}
\cleardoublepage

% ── Table of Contents ───────────────────────────────────────
\tableofcontents
\cleardoublepage

\mainmatter

$body$

\end{document}
