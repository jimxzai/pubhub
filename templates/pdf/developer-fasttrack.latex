% ============================================================
% DECORATIVE SECTION SEPARATOR - TikZ diamond ornament
% ============================================================
\newcommand{\ornsep}{%
  \par\vskip 12pt
  \begin{center}
  \begin{tikzpicture}
    % Left line
    \draw[color=accentgold!60, line width=0.5pt] (0,0) -- (2,0);
    % Diamond
    \filldraw[color=accentgold] (2.3,0) -- (2.5,0.15) -- (2.7,0) -- (2.5,-0.15) -- cycle;
    % Right line
    \draw[color=accentgold!60, line width=0.5pt] (2.7,0) -- (4.7,0);
  \end{tikzpicture}
  \end{center}
  \par\vskip 12pt
}

