\usepackage{fancyhdr}

\pagestyle{fancy}
\fancyhf{}
\fancyhead[LE]{\small\textcolor{chapterblue}{\nouppercase{\leftmark}}}
\fancyhead[RO]{\small\textcolor{chapterblue}{\nouppercase{\rightmark}}}
\fancyfoot[C]{\small\textcolor{chapterblue!60}{\thepage}}
\fancyfoot[LE]{\footnotesize\textcolor{chapterblue!30}{\textit{California Developer Fast Track Guide}}}
\fancyfoot[RO]{\footnotesize\textcolor{chapterblue!30}{\textit{Jim Xiao}}}
\renewcommand{\headrulewidth}{0.4pt}
\renewcommand{\headrule}{\hbox to\headwidth{\color{chapterblue!40}\leaders\hrule height \headrulewidth\hfill}}
\renewcommand{\footrulewidth}{0.4pt}
