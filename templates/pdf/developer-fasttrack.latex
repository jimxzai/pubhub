\documentclass[11pt,openany,twoside]{book}

% ============================================================
% FONTS - Professional Book Typography
% ============================================================
\usepackage{fontspec}

% Option 1: Libertinus (free, elegant, designed for books)
% Uncomment if you have Libertinus fonts installed:
% \setmainfont{Libertinus Serif}[
%   Numbers=OldStyle,
%   Ligatures=TeX,
%   Ligatures=Common
% ]
% \setsansfont{Libertinus Sans}
% \setmonofont{JetBrains Mono}[Scale=0.88]

% Option 2: Palatino (Hermann Zapf classic, professional reference standard)
% Clear lining numbers, excellent readability for technical/legal content
\setmainfont{Palatino}[
  BoldFont=Palatino Bold,
  ItalicFont=Palatino Italic,
  BoldItalicFont=Palatino Bold Italic,
  Numbers=Lining,
  Ligatures=TeX
]
\setsansfont{Avenir Next}[
  BoldFont=Avenir Next Bold,
  ItalicFont=Avenir Next Italic,
  Scale=0.95
]
\setmonofont{Source Code Pro}[
  Scale=0.85
]

% Option 3: EB Garamond (free classical elegance)
% Uncomment if you have EB Garamond installed:
% \setmainfont{EB Garamond}[
%   Numbers=OldStyle,
%   Ligatures=TeX
% ]
% \setsansfont{Source Sans 3}
% \setmonofont{Source Code Pro}[Scale=0.88]

% ============================================================
% CJK FONT SUPPORT
% ============================================================
\usepackage{xeCJK}

% CJK fonts - Use SC (Simplified Chinese) for better compatibility
% These fonts are standard on macOS and cover all Chinese characters
\setCJKmainfont{Songti SC}
\setCJKsansfont{Heiti SC}
\setCJKmonofont{Heiti SC}

% CJK line breaking support
\XeTeXlinebreaklocale "zh"
\XeTeXlinebreakskip = 0pt plus 1pt minus 0.1pt

