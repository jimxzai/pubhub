  % I AM statements
  \node[font=\small,anchor=west,color=TextGray] at (0.2,3.5) {1. 浪子的比喻 Prodigal Son (路 15:11-32)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,3.0) {2. 好撒瑪利亞人 Good Samaritan (路 10:25-37)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,2.5) {3. 葡萄園的工人 Workers in the Vineyard (太 20:1-16)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,2.0) {4. 十童女的比喻 Ten Virgins (太 25:1-13)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,1.5) {5. 按才幹受託 Talents (太 25:14-30)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,1.0) {6. 綿羊與山羊 Sheep and Goats (太 25:31-46)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,0.5) {7. 兩種根基 Two Foundations (太 7:24-27)};
\end{tikzpicture}%
}%% ============================================
%% PARABLES STRUCTURE DIAGRAM
%% ============================================
\newcommand{\parablesstructure}{%
\begin{tikzpicture}[scale=0.85]
  % Title
  \node[font=\large\bfseries,color=ChapterBlue] at (4.5,5.5) {耶穌比喻結構 Classification of Parables};

  % Boxes
  \node[draw=ScriptureGold,fill=ScriptureBg,rounded corners=5pt,
        minimum width=2.5cm,minimum height=0.8cm,font=\small\bfseries,
        drop shadow={opacity=0.3},align=center] (mystery) at (1,4) {天國奧祕\\Kingdom Secrets};
  \node[font=\tiny,color=LightGray] at (1,3.2) {馬太13章等};

  \node[draw=ChapterBlue,fill=ScriptureBg,rounded corners=5pt,
        minimum width=2.5cm,minimum height=0.8cm,font=\small\bfseries,
        drop shadow={opacity=0.3},align=center] (grace) at (4.5,4) {恩典主權\\Grace \& Sovereignty};
  \node[font=\tiny,color=LightGray] at (4.5,3.2) {浪子、葡萄園工人等};

  \node[draw=JesusRed,fill=ScriptureBg,rounded corners=5pt,
        minimum width=2.5cm,minimum height=0.8cm,font=\small\bfseries,
        drop shadow={opacity=0.3},align=center] (watch) at (8,4) {警醒預備\\Watchfulness};
  \node[font=\tiny,color=LightGray] at (8,3.2) {十童女、按才幹等};

  % Key themes
  \node[font=\tiny,color=CommentaryBrown] at (1,2.3) {啟示與遮蔽};
  \node[font=\tiny,color=CommentaryBrown] at (4.5,2.3) {憐憫與賜予};
  \node[font=\tiny,color=JesusRed] at (8,2.3) {忠心與交帳};
\end{tikzpicture}%
}


%% HOLY LAND MAP (Full Page)
%% ============================================
\newcommand{\holylandmap}{%
\begin{tikzpicture}[scale=1.0]
  % Background - Land
  \fill[LandBeige] (0,0) rectangle (10,12);

  % Mediterranean Sea
  \fill[WaterBlue] (-0.5,0) rectangle (1.8,12);
  \draw[SeaDark,line width=0.8pt] (1.8,0) -- (1.8,12);
  \node[font=\normalsize,color=ChapterBlue,rotate=90] at (0.6,6) {Mediterranean Sea 地中海};

  % Sea of Galilee
  \fill[WaterBlue] (6.2,9.2) ellipse (1 and 1.3);
  \draw[SeaDark,line width=0.5pt] (6.2,9.2) ellipse (1 and 1.3);
  \node[font=\small,color=white] at (6.2,9.4) {Sea of Galilee};
  \node[font=\small,color=white] at (6.2,8.9) {加利利海};

  % Jordan River
  \draw[WaterBlue,line width=2.5pt] (6.2,7.9)
    .. controls (5.8,7) and (6.3,6) .. (6,5)
    .. controls (5.7,4) and (6.2,3) .. (6,2);
  \node[font=\footnotesize,color=SeaDark,rotate=-75] at (5.4,5.5) {Jordan River 約旦河};

  % Dead Sea
  \fill[WaterBlue!70!SeaDark] (6,1) ellipse (0.7 and 0.9);
  \draw[SeaDark,line width=0.5pt] (6,1) ellipse (0.7 and 0.9);
  \node[font=\small,color=white] at (6,1.1) {Dead Sea};
  \node[font=\small,color=white] at (6,0.6) {死海};

  % Mountain regions (shading)
  \fill[MountainBrown!25] (7.5,6) ellipse (1.6 and 2.2);
  \fill[MountainBrown!20] (3.5,7.5) ellipse (1.1 and 1.6);

  % ========== KEY LOCATIONS ==========

  % Cana - Wedding miracle
  \fill[ScriptureGold] (4.8,10.5) circle (0.16);
  \draw[ScriptureGold,line width=0.8pt] (4.8,10.5) circle (0.23);
  \node[font=\normalsize\bfseries,right,color=ChapterBlue] at (5.1,10.5) {Cana 迦拿};
  \node[font=\footnotesize,right,color=TextGray] at (5.1,10.1) {Water to Wine 水變酒 (2:1-11)};

  % Capernaum
  \fill[ScriptureGold] (6.7,10.3) circle (0.16);
  \draw[ScriptureGold,line width=0.8pt] (6.7,10.3) circle (0.23);
  \node[font=\normalsize\bfseries,right,color=ChapterBlue] at (7,10.3) {Capernaum};
  \node[font=\footnotesize,right,color=TextGray] at (7,9.9) {迦百農 (4:46, 6:59)};

  % Nazareth
  \fill[ScriptureGold] (3.8,9.5) circle (0.14);
  \node[font=\small,left,color=ChapterBlue] at (3.6,9.5) {Nazareth 拿撒勒};

  % Bethsaida
  \fill[ScriptureGold] (7.1,9.5) circle (0.12);
  \node[font=\footnotesize,right,color=TextGray] at (7.3,9.5) {Bethsaida 伯賽大};

  % Sychar (Samaria)
  \fill[ScriptureGold] (5.5,7) circle (0.16);
  \draw[ScriptureGold,line width=0.8pt] (5.5,7) circle (0.23);
  \node[font=\normalsize\bfseries,left,color=ChapterBlue] at (5.2,7) {Sychar 敘加};
  \node[font=\footnotesize,left,color=TextGray] at (5.2,6.6) {Samaritan Woman (4:5)};

  % Bethany beyond Jordan
  \fill[ScriptureGold] (7.2,4.8) circle (0.14);
  \node[font=\footnotesize,right,color=TextGray] at (7.4,4.8) {Bethany beyond Jordan};
  \node[font=\footnotesize,right,color=TextGray] at (7.4,4.4) {約旦河外伯大尼 (1:28)};

  % Bethany near Jerusalem
  \fill[ScriptureGold] (6.8,3.4) circle (0.16);
  \draw[ScriptureGold,line width=0.8pt] (6.8,3.4) circle (0.23);
  \node[font=\normalsize\bfseries,right,color=ChapterBlue] at (7.1,3.4) {Bethany 伯大尼};
  \node[font=\footnotesize,right,color=TextGray] at (7.1,3) {Lazarus Raised (11:1-44)};

  % JERUSALEM - Central focus
  \fill[JesusRed] (5.5,3.8) circle (0.22);
  \draw[JesusRed,line width=1.5pt] (5.5,3.8) circle (0.32);
  \node[font=\Large\bfseries,left,color=JesusRed] at (5.1,3.8) {JERUSALEM};
  \node[font=\normalsize,left,color=JesusRed] at (5.1,3.3) {耶路撒冷};
  \node[font=\footnotesize,left,color=TextGray] at (5.1,2.9) {Temple, Bethesda, Siloam};
  \node[font=\footnotesize,left,color=TextGray] at (5.1,2.5) {Passion \& Resurrection};

  % Bethlehem
  \fill[ScriptureGold] (5,3.1) circle (0.12);
  \node[font=\footnotesize,left,color=TextGray] at (4.8,3.1) {Bethlehem 伯利恆};

  % ========== COMPASS ==========
  \draw[->,very thick,color=ChapterBlue] (9,10.5) -- (9,11.3);
  \draw[->,thick,color=ChapterBlue] (8.5,10.5) -- (9.5,10.5);
  \node[font=\normalsize\bfseries,color=ChapterBlue] at (9,11.6) {N};

  % ========== SCALE ==========
  \draw[very thick,color=TextGray] (2.5,0.5) -- (4.5,0.5);
  \draw[thick,color=TextGray] (2.5,0.35) -- (2.5,0.65);
  \draw[thick,color=TextGray] (4.5,0.35) -- (4.5,0.65);
  \node[font=\small,color=TextGray] at (3.5,0.15) {50 km / 30 miles};

  % ========== LEGEND ==========
  \fill[ScriptureBg,rounded corners=3pt] (0.3,10.8) rectangle (3,12.1);
  \draw[ScriptureGold,line width=0.8pt,rounded corners=3pt] (0.3,10.8) rectangle (3,12.1);
  \node[font=\small\bfseries,color=ChapterBlue] at (1.65,11.8) {Legend 圖例};
  \fill[JesusRed] (0.6,11.45) circle (0.1);
  \node[font=\footnotesize,right,color=TextGray] at (0.8,11.45) {Jerusalem};
  \fill[ScriptureGold] (0.6,11.1) circle (0.08);
  \node[font=\footnotesize,right,color=TextGray] at (0.8,11.1) {Key Location};
\end{tikzpicture}%
}

