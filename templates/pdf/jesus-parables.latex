% Command for Jesus's words - inspired by ai-eden.com
\newcommand{\jesus}[1]{\textcolor{JesusRed}{\textit{#1}}}

%% ============================================
%% VINE DECORATIONS
%% ============================================

% Simple vine decoration with leaves
\newcommand{\vinedecor}[1]{%
\begin{tikzpicture}[scale=0.6]
  \draw[color=VineGreen,line width=0.8pt,decorate,decoration={snake,amplitude=1.2pt,segment length=10pt}]
    (0,0) -- (#1,0);
  \foreach \x in {0.4,1.0,1.6,2.2,2.8} {
    \pgfmathparse{\x < #1 ? 1 : 0}
    \ifnum\pgfmathresult=1
      \draw[color=VineGreen,line width=0.5pt] (\x,0) .. controls (\x+0.1,0.18) and (\x+0.22,0.18) .. (\x+0.28,0.06);
      \draw[color=VineGreen,line width=0.4pt] (\x+0.15,0.12) .. controls (\x+0.2,0.2) .. (\x+0.3,0.15);
    \fi
  }
\end{tikzpicture}%
}

% Grape cluster decoration
\newcommand{\grapecluster}{%
\begin{tikzpicture}[scale=0.3]
  % Stem
  \draw[color=VineGreen,line width=0.8pt] (0,0.8) -- (0,0.4);
  % Grapes
  \foreach \x/\y in {0/0, -0.2/-0.25, 0.2/-0.25, -0.1/-0.5, 0.1/-0.5, 0/-0.75} {
    \fill[color=GrapesPurple] (\x,\y) circle (0.12);
  }
  % Leaf
  \draw[color=VineGreen,fill=VineGreen!30,line width=0.4pt]
    (0.3,0.6) .. controls (0.5,0.8) and (0.6,0.6) .. (0.4,0.4)
    .. controls (0.3,0.5) .. (0.3,0.6);
\end{tikzpicture}%
}

% Cross decoration
\newcommand{\crosssymbol}{%
\begin{tikzpicture}[scale=0.15]
  \draw[color=ScriptureGold,line width=1.5pt] (0,-1) -- (0,1);
  \draw[color=ScriptureGold,line width=1.5pt] (-0.6,0.4) -- (0.6,0.4);
\end{tikzpicture}%
}

% Ornament line
\newcommand{\ornamentline}{%
  \begin{center}
    \vspace{0.3em}
    {\color{ScriptureGold}\rule{0.3\textwidth}{0.5pt}%
    \hspace{0.5em}\ensuremath{\diamond}\hspace{0.5em}%
    \rule{0.3\textwidth}{0.5pt}}
    \vspace{0.3em}
  \end{center}
}

%% ============================================
%% KINGDOM PARABLES BOX
%% ============================================
\newcommand{\kingdomparablesbox}{%
\begin{tikzpicture}[scale=0.75]
  % Background
  \fill[SignsBg,rounded corners=8pt] (-0.3,-0.3) rectangle (8.5,4.8);
  \draw[ScriptureGold,line width=1.5pt,rounded corners=8pt] (-0.3,-0.3) rectangle (8.5,4.8);

  % Title
  \node[font=\large\bfseries,color=ChapterBlue] at (4.1,4.3) {天國的奧祕 Kingdom Parables (太 13)};

  % Divider
  \draw[ScriptureGold,line width=0.8pt] (0.2,3.9) -- (8,3.9);

  % Signs list
  \node[font=\small,anchor=west,color=TextGray] at (0.2,3.5) {1. 撒種的比喻 Sower (13:1-23)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,3.0) {2. 稗子的比喻 Weeds (13:24-43)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,2.5) {3. 芥菜種的比喻 Mustard Seed (13:31-32)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,2.0) {4. 麵酵的比喻 Leaven (13:33)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,1.5) {5. 藏寶的比喻 Hidden Treasure (13:44)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,1.0) {6. 尋珠的比喻 Pearl of Great Price (13:45-46)};
  \node[font=\small,anchor=west,color=TextGray] at (0.2,0.5) {7. 撒網的比喻 Net (13:47-50)};

  % Decorative grape
  \node at (7.8,0.5) {\grapecluster};
\end{tikzpicture}%
}

%% ============================================
%% GRACE AND WATCHFULNESS BOX
