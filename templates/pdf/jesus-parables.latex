\newcommand{\graceandwatchfulnessbox}{%
\begin{tikzpicture}[scale=0.75]
  % Background
  \fill[IAmBg,rounded corners=8pt] (-0.3,-0.3) rectangle (8.5,4.8);
  \draw[ChapterBlue,line width=1.5pt,rounded corners=8pt] (-0.3,-0.3) rectangle (8.5,4.8);

  % Title
  \node[font=\large\bfseries,color=JesusRed] at (4.1,4.3) {恩典與警醒 Grace \& Watchfulness};

  % Divider
