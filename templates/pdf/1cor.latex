% PubHub 1 Corinthians Template
% 哥林多前書研讀 - Professional Bible Study Layout
% Bilingual Chinese/English with Greek word studies
% Theme: Holy Spirit's Five-Fold Work + Resurrection Hope
% Requires XeLaTeX for CJK support

\documentclass[11pt,openany]{book}

%% ============================================
%% FONT SETUP WITH CJK LINE BREAKING
%% ============================================
\usepackage{fontspec}

\setmainfont{Songti SC}[
  BoldFont=Songti SC Bold,
  ItalicFont=Kaiti SC
]
\setsansfont{PingFang SC}
\setmonofont{Menlo}

%% Greek and Hebrew font support - auto-switch for Unicode blocks
\usepackage{ucharclasses}
\newfontfamily\greekfont{Times New Roman}[Script=Greek]
\newfontfamily\hebrewfont{Times New Roman}[Script=Hebrew]
\setTransitionsFor{Greek}{\greekfont}{\normalfont}
\setTransitionsFor{GreekExtended}{\greekfont}{\normalfont}
\setTransitionsFor{Hebrew}{\hebrewfont}{\normalfont}

%% Enable CJK line breaking - critical for Chinese text
\XeTeXlinebreaklocale "zh"
\XeTeXlinebreakskip = 0pt plus 1pt minus 0.1pt

%% ============================================
%% PAGE GEOMETRY - Fixed margins
%% ============================================
\usepackage{geometry}
\geometry{
  paperwidth=7in,
  paperheight=10in,
  top=0.75in,
  bottom=0.75in,
  inner=0.8in,
  outer=0.65in,
  marginparwidth=0in,
  marginparsep=0in
}

%% ============================================
%% LINE AND PARAGRAPH SPACING
%% ============================================
\linespread{1.1}
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.3em}

%% ============================================
%% COLOR SCHEME - 1 Corinthians Theme
%% Purple/Gold + Holy Spirit Blue
%% ============================================
\usepackage{xcolor}

% Primary colors
\definecolor{ChapterPurple}{RGB}{75,35,95}         % Deep purple
\definecolor{ScriptureGold}{RGB}{165,125,55}       % Gold
\definecolor{SpiritBlue}{RGB}{50,100,150}          % Holy Spirit blue
\definecolor{ResurrectionGold}{RGB}{200,160,60}    % Resurrection glory

% Box colors
\definecolor{ScriptureBg}{RGB}{252,250,245}        % Cream for scripture
\definecolor{GreekBg}{RGB}{248,245,252}            % Light purple for Greek
\definecolor{ApplicationBg}{RGB}{248,252,248}      % Light green
\definecolor{SpiritBg}{RGB}{245,250,255}           % Light blue for Spirit

% Text colors
\definecolor{TextGray}{RGB}{50,50,50}
\definecolor{LightGray}{RGB}{120,120,120}

% Red Letter Bible - Jesus's words
\definecolor{JesusRed}{RGB}{180,30,30}
\newcommand{\jesus}[1]{{\color{JesusRed}#1}}

%% ============================================
%% MATH AND SYMBOLS
%% ============================================
\usepackage{amssymb}
\usepackage{amsmath}

%% ============================================
%% GRAPHICS AND TIKZ
%% ============================================
\usepackage{graphicx}
\usepackage{tikz}
\usetikzlibrary{shapes,arrows,positioning,fit,backgrounds,calc,decorations.pathmorphing,decorations.pathreplacing}

%% ============================================
%% TIKZ DECORATIONS
%% ============================================

% Cross decoration
\newcommand{\crosssymbol}{%
\begin{tikzpicture}[scale=0.15]
  \draw[color=ScriptureGold,line width=1.5pt] (0,-1) -- (0,1);
  \draw[color=ScriptureGold,line width=1.5pt] (-0.6,0.4) -- (0.6,0.4);
\end{tikzpicture}%
}

% Dove symbol (Holy Spirit)
\newcommand{\dovesymbol}{%
\begin{tikzpicture}[scale=0.12]
  \draw[color=SpiritBlue,line width=1pt] (0,0) ellipse (1 and 0.5);
  \draw[color=SpiritBlue,line width=1pt] (-1,0) -- (-1.5,0.3) -- (-1,0.1);
  \draw[color=SpiritBlue,line width=1pt] (1,0) -- (1.3,0);
\end{tikzpicture}%
}

% Map colors
\definecolor{WaterBlue}{RGB}{180,210,230}
\definecolor{LandBeige}{RGB}{245,235,220}
\definecolor{SeaDark}{RGB}{100,140,170}

%% ============================================
%% CORINTH MAP - Ancient Corinth and Surroundings
%% ============================================
\newcommand{\corinthmap}{%
\begin{tikzpicture}[scale=0.85]
  % Background - Land
  \fill[LandBeige] (0,0) rectangle (12,10);

  % Corinthian Gulf (top)
  \fill[WaterBlue] (0,8) rectangle (12,10);
  \draw[SeaDark,line width=1pt] (0,8) -- (12,8);
  \node[font=\small,color=SeaDark] at (6,9) {Corinthian Gulf 哥林多灣};

  % Saronic Gulf (bottom right)
  \fill[WaterBlue] (8,0) rectangle (12,3);
  \draw[SeaDark,line width=1pt] (8,0) -- (8,3) -- (12,3);
  \node[font=\small,color=SeaDark,rotate=90] at (10.5,1.5) {Saronic Gulf};

  % Isthmus of Corinth (narrow land bridge)
  \fill[LandBeige!80!brown] (4,3) rectangle (8,8);
  \node[font=\scriptsize,color=TextGray,rotate=90] at (6,5.5) {Isthmus 地峽};

  % ========== KEY LOCATIONS ==========

  % CORINTH - Central focus
  \fill[ChapterPurple] (5.5,6) circle (0.25);
  \draw[ChapterPurple,line width=2pt] (5.5,6) circle (0.4);
  \node[font=\large\bfseries,right,color=ChapterPurple] at (5.9,6.2) {CORINTH};
  \node[font=\normalsize,right,color=ChapterPurple] at (5.9,5.6) {哥林多};

  % Cenchreae (eastern port)
  \fill[SpiritBlue] (7.5,4) circle (0.15);
  \node[font=\small,right,color=TextGray] at (7.7,4) {Cenchreae 堅革哩};
  \node[font=\scriptsize,right,color=LightGray] at (7.7,3.6) {Eastern Port 東港};

  % Lechaeum (western port)
  \fill[SpiritBlue] (4,7.5) circle (0.15);
  \node[font=\small,left,color=TextGray] at (3.8,7.5) {Lechaeum 利恰音};
  \node[font=\scriptsize,left,color=LightGray] at (3.8,7.1) {Western Port 西港};

  % Athens (to the east)
  \fill[ScriptureGold] (10,5) circle (0.18);
  \node[font=\small,right,color=TextGray] at (10.2,5) {Athens 雅典};
  \node[font=\scriptsize,right,color=LightGray] at (10.2,4.6) {50 km east};

  % Acrocorinth (fortress hill)
  \fill[ResurrectionGold] (5.2,5) circle (0.12);
  \node[font=\scriptsize,left,color=TextGray] at (5,5) {Acrocorinth};
  \node[font=\tiny,left,color=LightGray] at (5,4.6) {衛城};

  % Trade route arrows
  \draw[->,line width=1.5pt,color=ScriptureGold] (2,9) -- (4,7.5);
  \draw[->,line width=1.5pt,color=ScriptureGold] (7.5,4) -- (9.5,2);
  \node[font=\scriptsize,color=ScriptureGold] at (2.5,8.3) {To Rome};
  \node[font=\scriptsize,color=ScriptureGold] at (9,2.8) {To Asia};

  % ========== COMPASS ==========
  \draw[->,very thick,color=ChapterPurple] (11,9) -- (11,9.7);
  \node[font=\normalsize\bfseries,color=ChapterPurple] at (11,9.9) {N};

  % ========== LEGEND ==========
  \fill[ScriptureBg,rounded corners=5pt] (0.2,0.2) rectangle (3.8,2.8);
  \draw[ScriptureGold,line width=1pt,rounded corners=5pt] (0.2,0.2) rectangle (3.8,2.8);
  \node[font=\small\bfseries,color=ChapterPurple] at (2,2.5) {Legend 圖例};
  \fill[ChapterPurple] (0.5,2) circle (0.1);
  \node[font=\scriptsize,right,color=TextGray] at (0.7,2) {Corinth 哥林多};
  \fill[SpiritBlue] (0.5,1.6) circle (0.08);
  \node[font=\scriptsize,right,color=TextGray] at (0.7,1.6) {Ports 港口};
  \fill[ScriptureGold] (0.5,1.2) circle (0.08);
  \node[font=\scriptsize,right,color=TextGray] at (0.7,1.2) {Other Cities};
  \draw[->,line width=1pt,color=ScriptureGold] (0.4,0.8) -- (0.8,0.8);
  \node[font=\scriptsize,right,color=TextGray] at (0.9,0.8) {Trade Routes};
\end{tikzpicture}%
}

%% ============================================
%% PAUL'S MISSIONARY JOURNEYS MAP
%% ============================================
\newcommand{\pauljourneysmap}{%
\begin{tikzpicture}[scale=0.68]
  % Background - Mediterranean Sea
  \fill[WaterBlue] (0,0) rectangle (16,11);

  % Land masses
  % Asia Minor (Turkey)
  \fill[LandBeige] (8,6) -- (16,6) -- (16,11) -- (8,11) -- (8,9) -- (10,8) -- (9,7) -- cycle;
  % Greece/Macedonia
  \fill[LandBeige] (3,6) -- (6,6) -- (6,9) -- (5,10) -- (3,10) -- (2,8) -- cycle;
  % Italy
  \fill[LandBeige] (0,7) -- (2,7) -- (2,11) -- (0,11) -- cycle;
  % Cyprus
  \fill[LandBeige] (9,3.5) ellipse (1.2 and 0.4);
  % Crete
  \fill[LandBeige] (6,3) ellipse (1 and 0.3);
  % Syria/Judea
  \fill[LandBeige] (12,0) -- (16,0) -- (16,5) -- (13,5) -- (12,3) -- cycle;
  % Egypt
  \fill[LandBeige] (8,0) -- (12,0) -- (12,2) -- (8,2) -- cycle;

  % Sea labels
  \node[font=\scriptsize,color=SeaDark] at (4,4) {Mediterranean Sea};
  \node[font=\tiny,color=SeaDark] at (4,3.5) {地中海};
  \node[font=\scriptsize,color=SeaDark] at (11,6.5) {Aegean};

  % ========== KEY CITIES ==========

  % ANTIOCH (Syria) - Starting point
  \fill[ChapterPurple] (14,4.5) circle (0.2);
  \node[font=\scriptsize\bfseries,right,color=ChapterPurple] at (14.2,4.5) {Antioch};
  \node[font=\tiny,right,color=TextGray] at (14.2,4.1) {安提阿};

  % Jerusalem
  \fill[ScriptureGold] (13.5,2) circle (0.18);
  \node[font=\scriptsize,right,color=TextGray] at (13.7,2) {Jerusalem 耶路撒冷};

  % Cyprus - Salamis & Paphos
  \fill[SpiritBlue] (9.8,3.5) circle (0.1);
  \node[font=\tiny,above,color=TextGray] at (9.8,3.7) {Salamis};
  \fill[SpiritBlue] (8.2,3.5) circle (0.1);
  \node[font=\tiny,above,color=TextGray] at (8.2,3.7) {Paphos};

  % Asia Minor cities
  \fill[SpiritBlue] (11,7.5) circle (0.12);
  \node[font=\tiny,above,color=TextGray] at (11,7.7) {Perga};

  \fill[SpiritBlue] (12,8.5) circle (0.12);
  \node[font=\tiny,right,color=TextGray] at (12.1,8.5) {Antioch Pisidia};

  \fill[SpiritBlue] (13,8.2) circle (0.12);
  \node[font=\tiny,right,color=TextGray] at (13.1,8.2) {Iconium 以哥念};

  \fill[SpiritBlue] (13.5,7.5) circle (0.12);
  \node[font=\tiny,right,color=TextGray] at (13.6,7.5) {Lystra 路司得};

  \fill[SpiritBlue] (14,7) circle (0.12);
  \node[font=\tiny,right,color=TextGray] at (14.1,7) {Derbe 特庇};

  % EPHESUS - Major church
  \fill[ResurrectionGold] (9.5,7) circle (0.18);
  \draw[ResurrectionGold,line width=1.5pt] (9.5,7) circle (0.28);
  \node[font=\scriptsize\bfseries,left,color=ResurrectionGold] at (9.2,7) {Ephesus};
  \node[font=\tiny,left,color=TextGray] at (9.2,6.6) {以弗所};

  % Troas
  \fill[SpiritBlue] (8.5,8.5) circle (0.1);
  \node[font=\tiny,left,color=TextGray] at (8.3,8.5) {Troas};

  % Macedonia/Greece cities
  \fill[SpiritBlue] (5.5,9.5) circle (0.12);
  \node[font=\tiny,above,color=TextGray] at (5.5,9.7) {Philippi 腓立比};

  \fill[SpiritBlue] (4.5,9) circle (0.12);
  \node[font=\tiny,left,color=TextGray] at (4.3,9) {Thessalonica};
  \node[font=\tiny,left,color=TextGray] at (4.3,8.6) {帖撒羅尼迦};

  \fill[SpiritBlue] (4,8.2) circle (0.1);
  \node[font=\tiny,left,color=TextGray] at (3.8,8.2) {Berea 庇哩亞};

  % Athens
  \fill[ScriptureGold] (5,6.8) circle (0.15);
  \node[font=\scriptsize,below,color=TextGray] at (5,6.5) {Athens 雅典};

  % CORINTH - Major church
  \fill[ChapterPurple] (4.5,6.5) circle (0.18);
  \draw[ChapterPurple,line width=1.5pt] (4.5,6.5) circle (0.28);
  \node[font=\scriptsize\bfseries,below,color=ChapterPurple] at (4.5,6.1) {CORINTH};
  \node[font=\tiny,below,color=ChapterPurple] at (4.5,5.7) {哥林多};

  % Rome
  \fill[ScriptureGold] (0.8,9) circle (0.18);
  \node[font=\scriptsize\bfseries,right,color=TextGray] at (1,9) {Rome 羅馬};

  % ========== JOURNEY ROUTES ==========

  % First Journey (AD 46-48) - Green dashed
  \draw[green!60!black,line width=2pt,dashed]
    (14,4.5) -- (9.8,3.5) -- (8.2,3.5) -- (11,7.5) -- (12,8.5) -- (13,8.2) -- (13.5,7.5) -- (14,7);
  \draw[green!60!black,line width=2pt,dashed]
    (14,7) -- (13.5,7.5) -- (13,8.2) -- (12,8.5) -- (11,7.5) -- (14,4.5);

  % Second Journey (AD 49-52) - Blue solid
  \draw[SpiritBlue,line width=2pt]
    (14,4.5) -- (14,7) -- (13.5,7.5) -- (13,8.2) -- (8.5,8.5) -- (5.5,9.5) -- (4.5,9) -- (4,8.2) -- (5,6.8) -- (4.5,6.5);
  \draw[SpiritBlue,line width=2pt]
    (4.5,6.5) -- (9.5,7) -- (14,4.5);

  % Third Journey (AD 53-57) - Purple dotted
  \draw[ChapterPurple,line width=2pt,dotted]
    (14,4.5) -- (13,8.2) -- (9.5,7);
  \draw[ChapterPurple,line width=2pt,dotted]
    (9.5,7) -- (8.5,8.5) -- (5.5,9.5) -- (4.5,6.5) -- (8.5,8.5) -- (9.5,7);
  \draw[ChapterPurple,line width=2pt,dotted]
    (9.5,7) -- (13.5,2) -- (0.8,9);

  % ========== LEGEND ==========
  \fill[ScriptureBg,rounded corners=5pt] (0.2,0.3) rectangle (7.5,2.5);
  \draw[ScriptureGold,line width=1pt,rounded corners=5pt] (0.2,0.3) rectangle (7.5,2.5);
  \node[font=\small\bfseries,color=ChapterPurple] at (3.8,2.2) {Paul's Missionary Journeys 保羅宣教之旅};

  \draw[green!60!black,line width=2pt,dashed] (0.5,1.7) -- (1.5,1.7);
  \node[font=\scriptsize,right,color=TextGray] at (1.6,1.7) {1st Journey 第一次 (AD 46-48)};

  \draw[SpiritBlue,line width=2pt] (0.5,1.2) -- (1.5,1.2);
  \node[font=\scriptsize,right,color=TextGray] at (1.6,1.2) {2nd Journey 第二次 (AD 49-52) - Corinth founded};

  \draw[ChapterPurple,line width=2pt,dotted] (0.5,0.7) -- (1.5,0.7);
  \node[font=\scriptsize,right,color=TextGray] at (1.6,0.7) {3rd Journey 第三次 (AD 53-57) - Letter written};

  % ========== COMPASS ==========
  \draw[->,very thick,color=ChapterPurple] (15,10) -- (15,10.7);
  \node[font=\normalsize\bfseries,color=ChapterPurple] at (15,10.9) {N};

\end{tikzpicture}%
}

%% ============================================
%% SEVEN CHURCHES OF REVELATION MAP
%% ============================================
\newcommand{\sevenchurchesmap}{%
\begin{tikzpicture}[scale=0.75]
  % Background - Aegean Sea
  \fill[WaterBlue] (0,0) rectangle (14,12);

  % Asia Minor (Western Turkey)
  \fill[LandBeige] (4,0) -- (14,0) -- (14,12) -- (4,12) -- (3,10) -- (2,8) -- (3,6) -- (2,4) -- (4,2) -- cycle;

  % Greek islands suggestions
  \fill[LandBeige] (1,7) ellipse (0.5 and 0.3);
  \fill[LandBeige] (0.5,5) ellipse (0.4 and 0.25);
  \fill[LandBeige] (2,3) ellipse (0.6 and 0.25);

  % Sea label
  \node[font=\small,color=SeaDark] at (1.5,9) {Aegean};
  \node[font=\small,color=SeaDark] at (1.5,8.5) {Sea};
  \node[font=\tiny,color=SeaDark] at (1.5,8) {愛琴海};

  % Region label
  \node[font=\large\bfseries,color=LandBeige!50!brown] at (10,10.5) {ASIA MINOR};
  \node[font=\normalsize,color=LandBeige!50!brown] at (10,9.8) {小亞細亞};

  % ========== THE SEVEN CHURCHES ==========
  % Circuit pattern: Ephesus -> Smyrna -> Pergamum -> Thyatira -> Sardis -> Philadelphia -> Laodicea

  % 1. EPHESUS (Rev 2:1-7) - Lost first love
  \fill[ChapterPurple] (5,3) circle (0.25);
  \draw[ChapterPurple,line width=2pt] (5,3) circle (0.4);
  \node[font=\normalsize\bfseries,right,color=ChapterPurple] at (5.5,3.2) {1. EPHESUS};
  \node[font=\small,right,color=TextGray] at (5.5,2.7) {以弗所};
  \node[font=\tiny,right,color=LightGray] at (5.5,2.3) {Rev 2:1-7 失去起初的愛};

  % 2. SMYRNA (Rev 2:8-11) - Suffering church
  \fill[SpiritBlue] (4.5,5.5) circle (0.22);
  \draw[SpiritBlue,line width=1.5pt] (4.5,5.5) circle (0.35);
  \node[font=\normalsize\bfseries,left,color=SpiritBlue] at (4,5.7) {2. SMYRNA};
  \node[font=\small,left,color=TextGray] at (4,5.2) {士每拿};
  \node[font=\tiny,left,color=LightGray] at (4,4.8) {Rev 2:8-11 受苦的教會};

  % 3. PERGAMUM (Rev 2:12-17) - Compromising church
  \fill[ScriptureGold] (5.5,8) circle (0.22);
  \draw[ScriptureGold,line width=1.5pt] (5.5,8) circle (0.35);
  \node[font=\normalsize\bfseries,left,color=ScriptureGold] at (5,8.2) {3. PERGAMUM};
  \node[font=\small,left,color=TextGray] at (5,7.7) {別迦摩};
  \node[font=\tiny,left,color=LightGray] at (5,7.3) {Rev 2:12-17 妥協的教會};

  % 4. THYATIRA (Rev 2:18-29) - Corrupt church
  \fill[ResurrectionGold] (7,7) circle (0.22);
  \draw[ResurrectionGold,line width=1.5pt] (7,7) circle (0.35);
  \node[font=\normalsize\bfseries,right,color=ResurrectionGold] at (7.5,7.2) {4. THYATIRA};
  \node[font=\small,right,color=TextGray] at (7.5,6.7) {推雅推喇};
  \node[font=\tiny,right,color=LightGray] at (7.5,6.3) {Rev 2:18-29 容讓罪惡};

  % 5. SARDIS (Rev 3:1-6) - Dead church
  \fill[LightGray] (8,5.5) circle (0.22);
  \draw[TextGray,line width=1.5pt] (8,5.5) circle (0.35);
  \node[font=\normalsize\bfseries,right,color=TextGray] at (8.5,5.7) {5. SARDIS};
  \node[font=\small,right,color=TextGray] at (8.5,5.2) {撒狄};
  \node[font=\tiny,right,color=LightGray] at (8.5,4.8) {Rev 3:1-6 死的教會};

  % 6. PHILADELPHIA (Rev 3:7-13) - Faithful church
  \fill[green!60!black] (9,4) circle (0.22);
  \draw[green!60!black,line width=1.5pt] (9,4) circle (0.35);
  \node[font=\normalsize\bfseries,right,color=green!60!black] at (9.5,4.2) {6. PHILADELPHIA};
  \node[font=\small,right,color=TextGray] at (9.5,3.7) {非拉鐵非};
  \node[font=\tiny,right,color=LightGray] at (9.5,3.3) {Rev 3:7-13 忠心的教會};

  % 7. LAODICEA (Rev 3:14-22) - Lukewarm church
  \fill[orange!70!red] (10.5,3) circle (0.22);
  \draw[orange!70!red,line width=1.5pt] (10.5,3) circle (0.35);
  \node[font=\normalsize\bfseries,right,color=orange!70!red] at (11,3.2) {7. LAODICEA};
  \node[font=\small,right,color=TextGray] at (11,2.7) {老底嘉};
  \node[font=\tiny,right,color=LightGray] at (11,2.3) {Rev 3:14-22 不冷不熱};

  % ========== CIRCUIT PATH ==========
  \draw[->,line width=2pt,color=ChapterPurple!70] (5,3.5) -- (4.5,5);
  \draw[->,line width=2pt,color=ChapterPurple!70] (4.7,5.9) -- (5.3,7.5);
  \draw[->,line width=2pt,color=ChapterPurple!70] (5.9,7.8) -- (6.6,7.2);
  \draw[->,line width=2pt,color=ChapterPurple!70] (7.2,6.6) -- (7.8,5.9);
  \draw[->,line width=2pt,color=ChapterPurple!70] (8.2,5.1) -- (8.8,4.4);
  \draw[->,line width=2pt,color=ChapterPurple!70] (9.3,3.7) -- (10.1,3.2);

  % Patmos (where John wrote)
  \fill[ChapterPurple] (2,3) circle (0.15);
  \node[font=\scriptsize\bfseries,below,color=ChapterPurple] at (2,2.7) {Patmos};
  \node[font=\tiny,below,color=TextGray] at (2,2.3) {拔摩島};
  \node[font=\tiny,below,color=LightGray] at (2,1.9) {John exiled};
  \draw[->,line width=1.5pt,dashed,color=ChapterPurple] (2.5,3) -- (4.5,3);

  % ========== LEGEND ==========
  \fill[ScriptureBg,rounded corners=5pt] (0.2,9.5) rectangle (3.5,11.8);
  \draw[ScriptureGold,line width=1pt,rounded corners=5pt] (0.2,9.5) rectangle (3.5,11.8);
  \node[font=\small\bfseries,color=ChapterPurple] at (1.85,11.5) {Seven Churches};
  \node[font=\small,color=ChapterPurple] at (1.85,11.1) {啟示錄七教會};
  \node[font=\tiny,color=TextGray] at (1.85,10.7) {Revelation 2-3};
  \node[font=\tiny,color=LightGray] at (1.85,10.3) {AD 95};
  \draw[->,line width=1.5pt,color=ChapterPurple!70] (0.5,9.9) -- (1.3,9.9);
  \node[font=\tiny,right,color=TextGray] at (1.4,9.9) {Circuit path};

  % ========== COMPASS ==========
  \draw[->,very thick,color=ChapterPurple] (13,11) -- (13,11.7);
  \node[font=\normalsize\bfseries,color=ChapterPurple] at (13,11.9) {N};

\end{tikzpicture}%
}

%% ============================================
%% ORNAMENT DIVIDER
%% ============================================
