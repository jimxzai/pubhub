%% ============================================
%% APPENDIX A: SCRIPTURE INDEX
%% ============================================
\chapter*{Appendix A: Scripture Index 經文索引}
\addcontentsline{toc}{chapter}{Appendix A: Scripture Index 經文索引}

\section*{舊約 Old Testament}

\begin{small}
\begin{tabular}{@{}p{3.5cm}p{3in}@{}}
\textbf{創世記 Genesis} & 創造、亞當、墮落 (Ch 15) \\
\textbf{出埃及記 Exodus} & 逾越節羔羊 (5:7)、曠野鑑戒 (10:1-13) \\
\textbf{詩篇 Psalms} & 基督的得勝 (15:25-27) \\
\textbf{以賽亞書 Isaiah} & 十字架的智慧 (1:19-21)、復活得勝 (15:54-55) \\
\textbf{何西阿書 Hosea} & 死的毒鉤 (15:55) \\
\end{tabular}
\end{small}

\section*{新約 New Testament}

\begin{small}
\begin{tabular}{@{}p{3.5cm}p{3in}@{}}
\textbf{馬太福音 Matthew} & 天國智慧、主的晚餐 \\
\textbf{約翰福音 John} & 聖靈的工作、復活與生命 \\
\textbf{使徒行傳 Acts} & 保羅在哥林多 (18章) \\
\textbf{羅馬書 Romans} & 因信稱義、恩賜運用 \\
\textbf{加拉太書 Galatians} & 聖靈的果子 \\
\textbf{以弗所書 Ephesians} & 教會合一、身體比喻 \\
\end{tabular}
\end{small}

\pagebreak

%% ============================================
%% APPENDIX B: KEY THEMES INDEX
%% ============================================
\chapter*{Appendix B: Key Themes 主題索引}
\addcontentsline{toc}{chapter}{Appendix B: Key Themes 主題索引}

\section*{聖靈的五重工作 The Spirit's Five-Fold Work}

\begin{small}
\begin{tabular}{@{}p{2.5cm}p{1.5cm}p{2.5in}@{}}
\textbf{智慧 Wisdom} & 1-4章 & 十字架的智慧 vs 世界的智慧 \\
\textbf{聖潔 Holiness} & 5-6章 & 身體是聖靈的殿 \\
\textbf{自由 Freedom} & 7-10章 & 愛中的自我約束 \\
\textbf{恩賜 Gifts} & 11-14章 & 合一的身體，愛的道路 \\
\textbf{盼望 Hope} & 15-16章 & 復活得勝，榮耀再來 \\
\end{tabular}
\end{small}

\section*{核心神學主題 Key Theological Themes}

\begin{small}
\begin{tabular}{@{}p{3.5cm}p{3in}@{}}
十字架的道理 & 1:18-2:16 — 神的智慧與能力 \\
身體是聖殿 & 6:19-20 — 聖靈內住的殿 \\
愛的真諦 & 13:1-13 — 最大的恩賜 \\
復活的盼望 & 15:1-58 — 所有問題的解答 \\
合一與多樣 & 12:12-27 — 一個身體，多個肢體 \\
\end{tabular}
\end{small}

\section*{希臘文關鍵詞 Key Greek Terms}

\begin{small}
\begin{tabular}{@{}p{3cm}p{3in}@{}}
\textbf{sophia} (σοφία) & 智慧 — 十字架的智慧 \\
\textbf{agape} (ἀγάπη) & 愛 — 永不止息的愛 \\
\textbf{pneumatikos} & 屬靈的 — 聖靈引導的生命 \\
\textbf{soma} (σῶμα) & 身體 — 聖靈的殿/基督的身體 \\
\textbf{charisma} (χάρισμα) & 恩賜 — 聖靈的禮物 \\
\textbf{anastasis} & 復活 — 榮耀的盼望 \\
\end{tabular}
\end{small}

